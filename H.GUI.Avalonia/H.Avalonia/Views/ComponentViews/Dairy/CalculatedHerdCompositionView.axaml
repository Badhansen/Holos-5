<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900"
             x:Class="H.Avalonia.Views.ComponentViews.Dairy.CalculatedHerdCompositionView">
  
  <!-- Calculated Herd Composition Panel - Flow Rate Method Only -->
  <Border Classes="step-container" 
          Background="#E8F5E9" 
          BorderBrush="#43A047" 
          Margin="0,0,0,20">
    <StackPanel>
      <!-- Step Header -->
      <StackPanel Classes="step-header">
        <Border Classes="step-badge" Background="#43A047">
          <TextBlock Text="??" Classes="step-badge-text" FontSize="14"/>
        </Border>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="Calculated Herd Composition" 
                     FontSize="16" 
                     FontWeight="Bold" 
                     Foreground="#605D5D"/>
          <TextBlock Text="Based on animals entering each stage per year (steady-state flow)" 
                     Classes="step-number-description"
                     Margin="0,4,0,0"/>
        </StackPanel>
      </StackPanel>
      
      <Grid ColumnDefinitions="*,*,*,*,Auto">
        <!-- Calves -->
        <Border Grid.Column="0" 
                Background="White" 
                CornerRadius="4" 
                Padding="12" 
                Margin="4">
          <StackPanel>
            <TextBlock Text="CALF" 
                       FontSize="14" 
                       FontWeight="Bold" 
                       Foreground="#1976D2" 
                       HorizontalAlignment="Center" 
                       Margin="0,8,0,8"/>
            <TextBlock Text="Calves" 
                       FontSize="12" 
                       FontWeight="SemiBold" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,4"/>
            <TextBlock Text="{Binding SelectedDairyComponentDto.SteadyStateCalves, StringFormat='{}{0} animals'}" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Foreground="#1976D2" 
                       HorizontalAlignment="Center"/>
            <TextBlock Text="120 days in stage" 
                       FontSize="10" 
                       Foreground="#666" 
                       HorizontalAlignment="Center" 
                       Margin="0,4,0,0"/>
          </StackPanel>
        </Border>
        
        <!-- Heifers -->
        <Border Grid.Column="1" 
                Background="White" 
                CornerRadius="4" 
                Padding="12" 
                Margin="4">
          <StackPanel>
            <TextBlock Text="HEIFER" 
                       FontSize="14" 
                       FontWeight="Bold" 
                       Foreground="#7B1FA2" 
                       HorizontalAlignment="Center" 
                       Margin="0,8,0,8"/>
            <TextBlock Text="Heifers" 
                       FontSize="12" 
                       FontWeight="SemiBold" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,4"/>
            <TextBlock Text="{Binding SelectedDairyComponentDto.SteadyStateHeifers, StringFormat='{}{0} animals'}" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Foreground="#7B1FA2" 
                       HorizontalAlignment="Center"/>
            <TextBlock Text="608 days in stage" 
                       FontSize="10" 
                       Foreground="#666" 
                       HorizontalAlignment="Center" 
                       Margin="0,4,0,0"/>
          </StackPanel>
        </Border>
        
        <!-- Lactating -->
        <Border Grid.Column="2" 
                Background="White" 
                CornerRadius="4" 
                Padding="12" 
                Margin="4">
          <StackPanel>
            <TextBlock Text="LACTATING" 
                       FontSize="14" 
                       FontWeight="Bold" 
                       Foreground="#388E3C" 
                       HorizontalAlignment="Center" 
                       Margin="0,8,0,8"/>
            <TextBlock Text="Lactating" 
                       FontSize="12" 
                       FontWeight="SemiBold" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,4"/>
            <TextBlock Text="{Binding SelectedDairyComponentDto.SteadyStateLactating, StringFormat='{}{0} animals'}" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Foreground="#388E3C" 
                       HorizontalAlignment="Center"/>
            <TextBlock Text="305 days in stage" 
                       FontSize="10" 
                       Foreground="#666" 
                       HorizontalAlignment="Center" 
                       Margin="0,4,0,0"/>
          </StackPanel>
        </Border>
        
        <!-- Dry -->
        <Border Grid.Column="3" 
                Background="White" 
                CornerRadius="4" 
                Padding="12" 
                Margin="4">
          <StackPanel>
            <TextBlock Text="DRY" 
                       FontSize="14" 
                       FontWeight="Bold" 
                       Foreground="#F57C00" 
                       HorizontalAlignment="Center" 
                       Margin="0,8,0,8"/>
            <TextBlock Text="Dry Cows" 
                       FontSize="12" 
                       FontWeight="SemiBold" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,4"/>
            <TextBlock Text="{Binding SelectedDairyComponentDto.SteadyStateDry, StringFormat='{}{0} animals'}" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Foreground="#F57C00" 
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding SelectedDairyComponentDto.DryPeriodDays, StringFormat='{}{0} days in stage'}" 
                       FontSize="10" 
                       Foreground="#666" 
                       HorizontalAlignment="Center" 
                       Margin="0,4,0,0"/>
          </StackPanel>
        </Border>
        
        <!-- Total -->
        <Border Grid.Column="4" 
                Background="#43A047" 
                CornerRadius="4" 
                Padding="16" 
                Margin="4"
                VerticalAlignment="Stretch">
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="TOTAL" 
                       FontSize="14" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,8"/>
            <TextBlock Text="{Binding SelectedDairyComponentDto.TotalSteadyStateHerdSize, StringFormat='{}{0}'}" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       HorizontalAlignment="Center"/>
            <TextBlock Text="animals" 
                       FontSize="12" 
                       Foreground="White" 
                       HorizontalAlignment="Center" 
                       Margin="0,4,0,0"/>
          </StackPanel>
        </Border>
      </Grid>
      
      <!-- Explanation -->
      <Border Background="White" 
              BorderBrush="#E0E0E0" 
              BorderThickness="1" 
              CornerRadius="4" 
              Padding="12" 
              Margin="4,8,4,4">
        <StackPanel>
          <TextBlock Text="?? Understanding Steady-State Populations" 
                     FontSize="12" 
                     FontWeight="SemiBold" 
                     Margin="0,0,0,8"/>
          <TextBlock TextWrapping="Wrap" 
                     FontSize="11" 
                     Foreground="#666" 
                     LineHeight="16">
            <Run Text="These numbers show how many animals will be in each stage at any given time in a steady-state operation. "/>
            <Run Text="Calculation: (Animals entering per year) × (Days in stage ÷ 365). "/>
            <Run Text="This method represents continuous calving operations where animals flow through stages year-round, " FontWeight="SemiBold"/>
            <Run Text="providing a more realistic model for emissions calculations and herd management."/>
          </TextBlock>
        </StackPanel>
      </Border>
    </StackPanel>
  </Border>
  
</UserControl>
