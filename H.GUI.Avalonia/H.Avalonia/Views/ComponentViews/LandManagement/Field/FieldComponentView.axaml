<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:field="clr-namespace:H.Avalonia.ViewModels.ComponentViews.LandManagement.Field"
             xmlns:fieldViews="clr-namespace:H.Avalonia.Views.ComponentViews.LandManagement.Field"
             xmlns:properties="clr-namespace:H.Avalonia.Infrastructure.Properties;assembly=H.Avalonia.Infrastructure"
             xmlns:avalonia="clr-namespace:H.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="950"
             x:Class="H.Avalonia.Views.ComponentViews.LandManagement.Field.FieldComponentView">

	<Design.DataContext>
		<field:FieldComponentViewModelDesign/>
	</Design.DataContext>

	<Grid>
		<Grid.RowDefinitions>
			<!-- Title -->
			<RowDefinition Height="Auto"/>
			<!-- Advanced Options Toggle -->
			<RowDefinition Height="Auto"/>
			<!-- Content -->
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0">
			<!-- Title -->
			<TextBox Classes="view-title" Text="{Binding Path=SelectedFieldSystemComponentDto.Name}"/>
			<Border Classes="title-underline"/>
		</StackPanel>

		<!-- Advanced Options Toggle Section -->
		<Border Grid.Row="1" 
		        Background="#F8F9FA" 
		        CornerRadius="8" 
		        Padding="16,12" 
		        BorderBrush="#E9ECEF" 
		        BorderThickness="1"
		        Margin="{StaticResource DefaultUserControlMargin}">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>
				
				<StackPanel Grid.Column="0" VerticalAlignment="Center">
					<TextBlock Text="Show Advanced Options" 
					          FontSize="15" FontWeight="SemiBold" 
					          Foreground="#495057" Margin="0,0,0,2"/>
					<TextBlock Text="Display additional configuration options for detailed field management across all steps" 
					          FontSize="11" Foreground="#6C757D" 
					          FontStyle="Italic"/>
				</StackPanel>
				
				<ToggleSwitch Grid.Column="1" 
				            Name="ShowAdvancedOptionsToggle"
				            VerticalAlignment="Center"
				            Margin="12,0,0,0"
				            OffContent="Basic"
				            OnContent="Advanced"
				            IsChecked="{Binding ShowAdvancedOptions, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
				            d:IsChecked="True"/>
			</Grid>
		</Border>

		<ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
			<Grid>
			<Grid.RowDefinitions>
				<!-- Step 1 row -->
                <RowDefinition Height="Auto"/>

                <!-- Step 1 GridSplitter row -->
				<RowDefinition Height="Auto"/>

                <!-- Step 2 row - Auto height to accommodate timeline -->
				<RowDefinition Height="Auto"/>

                <!-- Step 2 GridSplitter row -->
				<RowDefinition Height="Auto"/>

                <!-- Step 3 row - Auto height to ensure visibility -->
				<RowDefinition Height="Auto"/>
				
			</Grid.RowDefinitions>

		<!-- Begin step 1 -->

		<Border Grid.Row="0"
		       Background="White" 
		       BorderBrush="LightGray" 
		       BorderThickness="1" 
		       CornerRadius="8" 
		       Padding="20"
		       Margin="{StaticResource DefaultUserControlMargin}">
				<Border.Styles>
					<Style Selector="Border">
						<Setter Property="BoxShadow" Value="0 2 8 0 #1A000000"/>
					</Style>
				</Border.Styles>
				
				<fieldViews:FieldComponentStep1View/>
			</Border>

			<!-- End step 1 -->

		<!-- Begin step 2 -->

		<Border Grid.Row="2"
		       Background="White" 
		       BorderBrush="LightGray" 
		       BorderThickness="1" 
		       CornerRadius="8" 
		       Padding="20"
		       Margin="{StaticResource DefaultUserControlMargin}">
				<Border.Styles>
					<Style Selector="Border">
						<Setter Property="BoxShadow" Value="0 2 8 0 #1A000000"/>
					</Style>
				</Border.Styles>
				
				<fieldViews:FieldComponentStep2View/>
			</Border>

			<!-- End step 2 -->

		<!-- Begin step 3 -->
		<Border Grid.Row="4"
		       Background="White" 
		       BorderBrush="LightGray" 
		       BorderThickness="1" 
		       CornerRadius="8" 
		       Padding="20"
		       Margin="{StaticResource DefaultUserControlMargin}">
				<Border.Styles>
					<Style Selector="Border">
						<Setter Property="BoxShadow" Value="0 2 8 0 #1A000000"/>
					</Style>
				</Border.Styles>
				
				<fieldViews:SelectedCropTabView x:Name="SelectedCropTabViewControl"/>
			</Border>

			<!-- End step 3 -->
			</Grid>
		</ScrollViewer>
	</Grid>
</UserControl>
