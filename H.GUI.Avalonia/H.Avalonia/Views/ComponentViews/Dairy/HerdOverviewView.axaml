<UserControl x:Name="HerdOverviewRootControl"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:converters="clr-namespace:H.Avalonia.Converters"
xmlns:dairy="clr-namespace:H.Avalonia.Views.ComponentViews.Dairy"
mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="400"
x:Class="H.Avalonia.Views.ComponentViews.Dairy.HerdOverviewView">
  
<UserControl.Resources>
  <converters:DivideByTwelveConverter x:Key="DivideByTwelveConverter"/>
</UserControl.Resources>
  
<!-- Step 1: Herd Parameters -->
  <Border x:Name="StepContainerBorder" Classes="step-container">
    <StackPanel>
      <!-- Step Header -->
      <StackPanel x:Name="StepHeaderPanel" Margin="0,0,0,20">
        <Border x:Name="StepBadgeBorder" Classes="step-badge" HorizontalAlignment="Left">
          <TextBlock x:Name="StepNumberTextBlock" Text="Step 1" Classes="step-badge-text"/>
        </Border>
        <TextBlock x:Name="StepDescriptionTextBlock"
                   Text="Define Herd Parameters"
                   Classes="step-number-description"
                   Margin="0,8,0,0"/>
      </StackPanel>
      
      <!-- Overview Content -->
      <Grid x:Name="OverviewContentGrid"
            ColumnDefinitions="Auto,*"
            Grid.IsSharedSizeScope="True">

        <!-- Lifecycle Parameters Section (Left) -->
        <Border x:Name="ProductionCycleCardBorder" 
                Grid.Column="0"
                Classes="input-card" 
                Margin="0,0,16,0"
                VerticalAlignment="Top">
          <StackPanel MinWidth="300">
            <TextBlock x:Name="ProductionCycleTitleTextBlock" 
                       Text="Lifecycle Parameters" 
                       FontWeight="Bold" 
                       Margin="0,0,0,12"/>
            
            <!-- Dry Period -->
            <Grid x:Name="DryPeriodRowGrid" Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                <ColumnDefinition Width="Auto" MinWidth="120" SharedSizeGroup="InputColumn"/>
                <ColumnDefinition Width="Auto" SharedSizeGroup="UnitColumn"/>
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="DryPeriodLabelTextBlock"
                         Grid.Column="0" 
                         Text="Dry Period:" 
                         FontWeight="Medium" 
                         Foreground="RoyalBlue"
                         VerticalAlignment="Center" 
                         Margin="0,0,8,0"/>
              <NumericUpDown x:Name="DryPeriodInputNumericUpDown"
                             Grid.Column="1" 
                             Minimum="0" 
                             Maximum="120"
                             FormatString="0"
                             Increment="5"
                             Value="{Binding Path=SelectedDairyComponentDto.DryPeriodDays}"
                             Margin="8,0"
                             HorizontalAlignment="Stretch"/>
              <TextBlock x:Name="DryPeriodUnitTextBlock"
                         Grid.Column="2" 
                         Text="days" 
                         VerticalAlignment="Center"
                         Margin="8,0,0,0"/>
            </Grid>
            
            <!-- Calf Stage Duration -->
            <Grid x:Name="CalfStageDurationRowGrid" Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                <ColumnDefinition Width="Auto" MinWidth="120" SharedSizeGroup="InputColumn"/>
                <ColumnDefinition Width="Auto" SharedSizeGroup="UnitColumn"/>
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="CalfStageDurationLabelTextBlock"
                         Grid.Column="0" 
                         Text="Calf Stage:" 
                         FontWeight="Medium" 
                         Foreground="RoyalBlue"
                         VerticalAlignment="Center" 
                         Margin="0,0,8,0"/>
              <NumericUpDown x:Name="CalfStageDurationInputNumericUpDown"
                             Grid.Column="1" 
                             Minimum="30" 
                             Maximum="365"
                             FormatString="0"
                             Increment="5"
                             Value="{Binding Path=SelectedDairyComponentDto.CalfStageDurationDays}"
                             Margin="8,0"
                             HorizontalAlignment="Stretch"/>
              <TextBlock x:Name="CalfStageDurationUnitTextBlock"
                         Grid.Column="2" 
                         Text="days" 
                         VerticalAlignment="Center"
                         Margin="8,0,0,0"/>
            </Grid>
            
            <!-- Heifer Stage Duration -->
            <Grid x:Name="HeiferStageDurationRowGrid" Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                <ColumnDefinition Width="Auto" MinWidth="120" SharedSizeGroup="InputColumn"/>
                <ColumnDefinition Width="Auto" SharedSizeGroup="UnitColumn"/>
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="HeiferStageDurationLabelTextBlock"
                         Grid.Column="0" 
                         Text="Heifer Stage:" 
                         FontWeight="Medium" 
                         Foreground="RoyalBlue"
                         VerticalAlignment="Center" 
                         Margin="0,0,8,0"/>
              <NumericUpDown x:Name="HeiferStageDurationInputNumericUpDown"
                             Grid.Column="1" 
                             Minimum="365" 
                             Maximum="1095"
                             FormatString="0"
                             Increment="10"
                             Value="{Binding Path=SelectedDairyComponentDto.HeiferStageDurationDays}"
                             Margin="8,0"
                             HorizontalAlignment="Stretch"/>
              <TextBlock x:Name="HeiferStageDurationUnitTextBlock"
                         Grid.Column="2" 
                         Text="days" 
                         VerticalAlignment="Center"
                         Margin="8,0,0,0"/>
            </Grid>
            
            <!-- Lactation Duration -->
            <Grid x:Name="LactationDurationRowGrid" Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                <ColumnDefinition Width="Auto" MinWidth="120" SharedSizeGroup="InputColumn"/>
                <ColumnDefinition Width="Auto" SharedSizeGroup="UnitColumn"/>
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="LactationDurationLabelTextBlock"
                         Grid.Column="0" 
                         Text="Lactation Period:" 
                         FontWeight="Medium" 
                         Foreground="RoyalBlue"
                         VerticalAlignment="Center" 
                         Margin="0,0,8,0"/>
              <NumericUpDown x:Name="LactationDurationInputNumericUpDown"
                             Grid.Column="1" 
                             Minimum="200" 
                             Maximum="400"
                             FormatString="0"
                             Increment="5"
                             Value="{Binding Path=SelectedDairyComponentDto.LactationDurationDays}"
                             Margin="8,0"
                             HorizontalAlignment="Stretch"/>
              <TextBlock x:Name="LactationDurationUnitTextBlock"
                         Grid.Column="2" 
                         Text="days" 
                         VerticalAlignment="Center"
                         Margin="8,0,0,0"/>
            </Grid>
            
           
          </StackPanel>
        </Border>
        
        <!-- Staggered Progression Steady-State Section (Right) -->
        <Border x:Name="StaggeredProgressionCardBorder" 
                Grid.Column="1"
                Classes="input-card" 
                Background="#FFF9E6" 
                BorderBrush="#FFA000" 
                BorderThickness="2"
                VerticalAlignment="Top">
          <StackPanel>
          <TextBlock x:Name="StaggeredProgressionTitleTextBlock"
                     Text="Steady-State Animal Populations" 
                     FontWeight="Bold" 
                     Margin="0,0,0,8"/>
          
          <!-- Help Text -->

          
          <!-- Calves Present -->
          <Grid x:Name="CalvesEnteringRowGrid" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
              <ColumnDefinition Width="Auto" MinWidth="120" SharedSizeGroup="InputColumn"/>
              <ColumnDefinition Width="Auto" SharedSizeGroup="UnitColumn"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="CalvesEnteringLabelTextBlock"
                       Grid.Column="0" 
                       Text="Calves Present:" 
                       FontWeight="Medium" 
                       Foreground="RoyalBlue"
                       VerticalAlignment="Center" 
                       Margin="0,0,8,0"/>
            <NumericUpDown x:Name="CalvesEnteringInputNumericUpDown"
                           Grid.Column="1" 
                           Minimum="0" 
                           Maximum="10000"
                           FormatString="0"
                           Increment="1"
                           Value="{Binding Path=SelectedDairyComponentDto.SteadyStateCalves}"
                           Margin="8,0"
                           HorizontalAlignment="Stretch"/>
            <TextBlock x:Name="CalvesEnteringUnitTextBlock"
                       Grid.Column="2" 
                       Text="animals" 
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"/>
          </Grid>
          
          <!-- Calves Flow Rate Calculated Tip -->
          <TextBlock x:Name="CalvesPerMonthTipTextBlock"
                     TextWrapping="Wrap" 
                     FontSize="11" 
                     Foreground="#666" 
                     FontStyle="Italic"
                     Margin="0,0,0,12"
                     IsVisible="{Binding ShowAdvancedOptions, RelativeSource={RelativeSource AncestorType={x:Type dairy:DairyComponentView}}}">
            <Run Text="💡 "/>
            <Run Text="{Binding SelectedDairyComponentDto.SteadyStateCalves, StringFormat='{}{0:N0}'}" FontWeight="SemiBold"/>
            <Run Text=" calves present ≈ "/>
            <Run Text="{Binding SelectedDairyComponentDto.CalvesEnteringPerYear, StringFormat='{}{0:F0}'}" FontWeight="SemiBold"/>
            <Run Text=" calves entering/year"/>
          </TextBlock>
          
          <!-- Heifers Present -->
          <Grid x:Name="HeifersEnteringRowGrid" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
              <ColumnDefinition Width="Auto" MinWidth="120" SharedSizeGroup="InputColumn"/>
              <ColumnDefinition Width="Auto" SharedSizeGroup="UnitColumn"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="HeifersEnteringLabelTextBlock"
                       Grid.Column="0" 
                       Text="Heifers Present:" 
                       FontWeight="Medium" 
                       Foreground="RoyalBlue"
                       VerticalAlignment="Center" 
                       Margin="0,0,8,0"/>
            <NumericUpDown x:Name="HeifersEnteringInputNumericUpDown"
                           Grid.Column="1" 
                           Minimum="0" 
                           Maximum="10000"
                           FormatString="0"
                           Increment="1"
                           Value="{Binding Path=SelectedDairyComponentDto.SteadyStateHeifers}"
                           Margin="8,0"
                           HorizontalAlignment="Stretch"/>
            <TextBlock x:Name="HeifersEnteringUnitTextBlock"
                       Grid.Column="2" 
                       Text="animals" 
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"/>
          </Grid>
          
          <!-- Heifers Flow Rate Calculated Tip -->
          <TextBlock x:Name="HeifersPerMonthTipTextBlock"
                     TextWrapping="Wrap" 
                     FontSize="11" 
                     Foreground="#666" 
                     FontStyle="Italic"
                     Margin="0,0,0,12"
                     IsVisible="{Binding ShowAdvancedOptions, RelativeSource={RelativeSource AncestorType={x:Type dairy:DairyComponentView}}}">
            <Run Text="💡 "/>
            <Run Text="{Binding SelectedDairyComponentDto.SteadyStateHeifers, StringFormat='{}{0:N0}'}" FontWeight="SemiBold"/>
            <Run Text=" heifers present ≈ "/>
            <Run Text="{Binding SelectedDairyComponentDto.HeifersEnteringPerYear, StringFormat='{}{0:F0}'}" FontWeight="SemiBold"/>
            <Run Text=" heifers entering/year"/>
          </TextBlock>
          
          <!-- Lactating Cows Present -->
          <Grid x:Name="LactatingEnteringRowGrid" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
              <ColumnDefinition Width="Auto" MinWidth="120" SharedSizeGroup="InputColumn"/>
              <ColumnDefinition Width="Auto" SharedSizeGroup="UnitColumn"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="LactatingEnteringLabelTextBlock"
                       Grid.Column="0" 
                       Text="Lactating Present:" 
                       FontWeight="Medium" 
                       Foreground="RoyalBlue"
                       VerticalAlignment="Center" 
                       Margin="0,0,8,0"/>
            <NumericUpDown x:Name="LactatingEnteringInputNumericUpDown"
                           Grid.Column="1" 
                           Minimum="0" 
                           Maximum="10000"
                           FormatString="0"
                           Increment="1"
                           Value="{Binding Path=SelectedDairyComponentDto.SteadyStateLactating}"
                           Margin="8,0"
                           HorizontalAlignment="Stretch"/>
            <TextBlock x:Name="LactatingEnteringUnitTextBlock"
                       Grid.Column="2" 
                       Text="animals" 
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"/>
          </Grid>
          
          <!-- Lactating Flow Rate Calculated Tip -->
          <TextBlock x:Name="LactatingPerMonthTipTextBlock"
                     TextWrapping="Wrap" 
                     FontSize="11" 
                     Foreground="#666" 
                     FontStyle="Italic"
                     Margin="0,0,0,12"
                     IsVisible="{Binding ShowAdvancedOptions, RelativeSource={RelativeSource AncestorType={x:Type dairy:DairyComponentView}}}">
            <Run Text="💡 "/>
            <Run Text="{Binding SelectedDairyComponentDto.SteadyStateLactating, StringFormat='{}{0:N0}'}" FontWeight="SemiBold"/>
            <Run Text=" cows present ≈ "/>
            <Run Text="{Binding SelectedDairyComponentDto.LactatingCowsEnteringPerYear, StringFormat='{}{0:F0}'}" FontWeight="SemiBold"/>
            <Run Text=" cows entering lactation/year"/>
          </TextBlock>
          
          <!-- Dry Cows Present -->
          <Grid x:Name="DryEnteringRowGrid" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
              <ColumnDefinition Width="Auto" MinWidth="120" SharedSizeGroup="InputColumn"/>
              <ColumnDefinition Width="Auto" SharedSizeGroup="UnitColumn"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="DryEnteringLabelTextBlock"
                       Grid.Column="0" 
                       Text="Dry Cows Present:" 
                       FontWeight="Medium" 
                       Foreground="RoyalBlue"
                       VerticalAlignment="Center" 
                       Margin="0,0,8,0"/>
            <NumericUpDown x:Name="DryEnteringInputNumericUpDown"
                           Grid.Column="1" 
                           Minimum="0" 
                           Maximum="10000"
                           FormatString="0"
                           Increment="1"
                           Value="{Binding Path=SelectedDairyComponentDto.SteadyStateDry}"
                           Margin="8,0"
                           HorizontalAlignment="Stretch"/>
            <TextBlock x:Name="DryEnteringUnitTextBlock"
                       Grid.Column="2" 
                       Text="animals" 
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"/>
          </Grid>
          
          <!-- Dry Flow Rate Calculated Tip -->
          <TextBlock x:Name="DryPerMonthTipTextBlock"
                     TextWrapping="Wrap" 
                     FontSize="11" 
                     Foreground="#666" 
                     FontStyle="Italic"
                     Margin="0,4,0,0"
                     IsVisible="{Binding ShowAdvancedOptions, RelativeSource={RelativeSource AncestorType={x:Type dairy:DairyComponentView}}}">
            <Run Text="💡 "/>
            <Run Text="{Binding SelectedDairyComponentDto.SteadyStateDry, StringFormat='{}{0:N0}'}" FontWeight="SemiBold"/>
            <Run Text=" cows present ≈ "/>
            <Run Text="{Binding SelectedDairyComponentDto.DryCowsEnteringPerYear, StringFormat='{}{0:F0}'}" FontWeight="SemiBold"/>
            <Run Text=" cows entering dry period/year"/>
          </TextBlock>
        </StackPanel>
      </Border>
    </Grid>
    </StackPanel>
  </Border>
  
</UserControl>
