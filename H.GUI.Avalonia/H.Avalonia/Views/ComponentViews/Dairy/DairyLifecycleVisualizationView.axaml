<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="H.Avalonia.Views.ComponentViews.Dairy.DairyLifecycleVisualizationView">

  <Border BorderBrush="#E0E0E0" 
          BorderThickness="2" 
          CornerRadius="8" 
          Background="White"
          Padding="24">
    <Grid RowDefinitions="Auto,*,Auto">
      
      <!-- Title -->
      <StackPanel Grid.Row="0" Margin="0,0,0,24">
        <TextBlock Text="Dairy Cattle Lifecycle" 
                   FontSize="20" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center"/>
        <TextBlock Text="Understanding the journey from birth to productive milking cow" 
                   FontSize="13" 
                   Foreground="#666" 
                   HorizontalAlignment="Center"
                   Margin="0,4,0,0"/>
      </StackPanel>

      <!-- Main Lifecycle Visualization -->
      <Canvas Grid.Row="1" 
              Width="1000"
              Height="350"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">

        <!-- Stage 1: Calf (Birth to 4 months) -->
        <Border Canvas.Left="25" 
                Canvas.Top="100"
                Width="180" 
                Height="140"
                Background="#E3F2FD" 
                BorderBrush="#1976D2" 
                BorderThickness="2"
                CornerRadius="12"
                Padding="16">
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="CALF" 
                       FontSize="16" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Foreground="#1976D2"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Birth - 4 months" 
                       FontSize="11" 
                       Foreground="#666"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Milk &amp; Starter Feed" 
                       FontSize="10" 
                       Foreground="#888"
                       FontStyle="Italic"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Arrow 1: Calf to Heifer -->
        <Path Canvas.Left="210" 
              Canvas.Top="165"
              Stroke="#424242" 
              StrokeThickness="3"
              Data="M 0,0 L 60,0 M 55,-5 L 60,0 L 55,5"/>
        <TextBlock Canvas.Left="220" 
                   Canvas.Top="145"
                   Text="Weaning" 
                   FontSize="10" 
                   Foreground="#666"
                   FontStyle="Italic"/>

        <!-- Stage 2: Heifer (4 months to First Calving ~24 months) -->
        <Border Canvas.Left="275" 
                Canvas.Top="100"
                Width="180" 
                Height="140"
                Background="#F3E5F5" 
                BorderBrush="#7B1FA2" 
                BorderThickness="2"
                CornerRadius="12"
                Padding="16">
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="HEIFER" 
                       FontSize="16" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Foreground="#7B1FA2"
                       Margin="0,0,0,8"/>
            <TextBlock Text="4 mo - First Calving" 
                       FontSize="11" 
                       Foreground="#666"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Growing Phase" 
                       FontSize="10" 
                       Foreground="#888"
                       FontStyle="Italic"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Arrow 2: Heifer to Lactating (straight horizontal) -->
        <Path Canvas.Left="460" 
              Canvas.Top="165"
              Stroke="#424242" 
              StrokeThickness="3"
              Data="M 0,0 L 60,0 M 55,-5 L 60,0 L 55,5"/>
        <TextBlock Canvas.Left="463" 
                   Canvas.Top="145"
                   Text="First Calving" 
                   FontSize="10" 
                   Foreground="#666"
                   FontWeight="Bold"/>

        <!-- Stage 3: Lactating Cow (Producing Milk) -->
        <Border Canvas.Left="525" 
                Canvas.Top="100"
                Width="200" 
                Height="140"
                Background="#E8F5E9" 
                BorderBrush="#388E3C" 
                BorderThickness="3"
                CornerRadius="12"
                Padding="16">
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="LACTATING COW" 
                       FontSize="16" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Foreground="#388E3C"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Milk Production" 
                       FontSize="11" 
                       Foreground="#666"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4"/>
            <TextBlock Text="~305 days lactation" 
                       FontSize="10" 
                       Foreground="#888"
                       FontStyle="Italic"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Arrow 3: Lactating to Dry (straight horizontal) -->
        <Path Canvas.Left="730" 
              Canvas.Top="165"
              Stroke="#424242" 
              StrokeThickness="3"
              Data="M 0,0 L 60,0 M 55,-5 L 60,0 L 55,5"/>
        <TextBlock Canvas.Left="738" 
                   Canvas.Top="145"
                   Text="Drying Off" 
                   FontSize="10" 
                   Foreground="#666"
                   FontWeight="Bold"/>

        <!-- Stage 4: Dry Cow (Pre-Calving Rest) -->
        <Border Canvas.Left="795" 
                Canvas.Top="100"
                Width="180" 
                Height="140"
                Background="#FFF3E0" 
                BorderBrush="#F57C00" 
                BorderThickness="2"
                CornerRadius="12"
                Padding="16">
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="DRY COW" 
                       FontSize="16" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Foreground="#F57C00"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Pre-Calving Rest" 
                       FontSize="11" 
                       Foreground="#666"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4"/>
            <TextBlock Text="~60 days" 
                       FontSize="10" 
                       Foreground="#888"
                       FontStyle="Italic"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Arrow 4: Dry back to Lactating (curved up - completing the cycle) -->
        <Path Canvas.Left="505" 
              Canvas.Top="95"
              Stroke="#424242" 
              StrokeThickness="3"
              StrokeDashArray="4,2"
              Data="M 380,0 Q 350,-40 10,-40 Q -30,-40 -30,0 M -35,-5 L -30,0 L -35,5"/>
        <TextBlock Canvas.Left="645" 
                   Canvas.Top="35"
                   Text="CALVING - Cycle Repeats" 
                   FontSize="11" 
                   Foreground="#D32F2F"
                   FontWeight="Bold"/>

        <!-- Culling/Replacement Arrow from Lactating down -->
        <Path Canvas.Left="625" 
              Canvas.Top="245"
              Stroke="#D32F2F" 
              StrokeThickness="2"
              StrokeDashArray="3,2"
              Data="M 0,0 L 0,50 M -5,45 L 0,50 L 5,45"/>
        <Border Canvas.Left="545" 
                Canvas.Top="300"
                Background="#FFEBEE"
                BorderBrush="#D32F2F"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,8">
          <StackPanel>
            <TextBlock Text="CULLING" 
                       FontSize="12" 
                       FontWeight="Bold"
                       Foreground="#D32F2F"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Based on replacement rate" 
                       FontSize="9" 
                       Foreground="#666"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Replacement Arrow from Heifer up to replace culled -->
        <Path Canvas.Left="365" 
              Canvas.Top="245"
              Stroke="#2E7D32" 
              StrokeThickness="2"
              StrokeDashArray="3,2"
              Data="M 0,0 L 0,50 M -5,45 L 0,50 L 5,45"/>
        <Border Canvas.Left="270" 
                Canvas.Top="300"
                Background="#E8F5E9"
                BorderBrush="#2E7D32"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,8">
          <StackPanel>
            <TextBlock Text="REPLACEMENT" 
                       FontSize="12" 
                       FontWeight="Bold"
                       Foreground="#2E7D32"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Heifers enter herd" 
                       FontSize="9" 
                       Foreground="#666"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

      </Canvas>

      <!-- Legend and Key Information -->
      <Border Grid.Row="2" 
              Background="#F5F5F5" 
              CornerRadius="6" 
              Padding="16"
              Margin="0,24,0,0">
        <Grid ColumnDefinitions="*,*,*">
          
          <!-- Key Concept 1 -->
          <StackPanel Grid.Column="0">
            <TextBlock Text="?? Key Concept: Herd Balance" 
                       FontSize="13" 
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"/>
            <TextBlock TextWrapping="Wrap" 
                       FontSize="11" 
                       Foreground="#666"
                       LineHeight="16">
              The number of animals in each stage is determined by your herd parameters. 
              Replacement rate controls how many heifers are needed, while dry period 
              determines the lactating/dry cow ratio.
            </TextBlock>
          </StackPanel>

          <!-- Key Concept 2 -->
          <StackPanel Grid.Column="1" Margin="16,0">
            <TextBlock Text="?? The Production Cycle" 
                       FontSize="13" 
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"/>
            <TextBlock TextWrapping="Wrap" 
                       FontSize="11" 
                       Foreground="#666"
                       LineHeight="16">
              After calving, cows lactate for ~305 days (10 months), then have a dry 
              period before the next calving. Your calving interval setting determines 
              how long this complete cycle takes.
            </TextBlock>
          </StackPanel>

          <!-- Key Concept 3 -->
          <StackPanel Grid.Column="2">
            <TextBlock Text="? Emissions Impact" 
                       FontSize="13" 
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"/>
            <TextBlock TextWrapping="Wrap" 
                       FontSize="11" 
                       Foreground="#666"
                       LineHeight="16">
              Each lifecycle stage has different feed requirements, manure production, 
              and emissions. Lactating cows have the highest emissions but also 
              produce valuable milk as the primary product.
            </TextBlock>
          </StackPanel>
          
        </Grid>
      </Border>
      
    </Grid>
  </Border>

</UserControl>
