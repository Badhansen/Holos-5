<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:rotation="clr-namespace:H.Avalonia.ViewModels.ComponentViews.LandManagement.Rotation"
             xmlns:rotationViews="clr-namespace:H.Avalonia.Views.ComponentViews.LandManagement.Rotation"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="400"
             x:Class="H.Avalonia.Views.ComponentViews.LandManagement.Rotation.RotationOverviewView">

    <Design.DataContext>
        <rotation:RotationComponentViewModelDesign/>
    </Design.DataContext>

    <!-- Step 1: Rotation Overview -->
    <Border Classes="step-container">
        <StackPanel>
            <!-- Step Header -->
            <StackPanel Margin="0,0,0,20">
                <Border Classes="step-badge" HorizontalAlignment="Left">
                    <TextBlock Text="Step 1" Classes="step-badge-text"/>
                </Border>
                <TextBlock Text="Define Rotation Parameters"
                           Classes="step-number-description"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Overview Content -->
            <Grid Grid.IsSharedSizeScope="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Time Period Section -->
                <Border Grid.Column="0" Classes="input-card" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="? Time Period" FontWeight="Bold" Margin="0,0,0,12"/>
                        
                        <!-- Start Year -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Start:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <NumericUpDown Grid.Column="1" 
                                           Minimum="1900" 
                                           Maximum="2200"
                                           FormatString="0"
                                           Increment="1"
                                           Value="{Binding Path=SelectedRotationComponentDto.StartYear}"/>
                        </Grid>

                        <!-- End Year -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="End:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <NumericUpDown Grid.Column="1" 
                                           Minimum="1900" 
                                           Maximum="2200"
                                           FormatString="0"
                                           Increment="1"
                                           Value="{Binding Path=SelectedRotationComponentDto.EndYear}"/>
                        </Grid>

                        <!-- Length (calculated) -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Length:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1" 
                                       Text="{Binding RotationLength}"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Field Configuration Section -->
                <rotationViews:RotationFieldConfigurationView Grid.Column="1" 
                                                              Margin="0,0,8,0"
                                                              DataContext="{Binding}"/>

                <!-- Rotation Summary Section -->
                <Border Grid.Column="2" Classes="input-card" Background="#E3F2FD">
                    <StackPanel>
                        <TextBlock Text="?? Rotation Summary" FontWeight="Bold" Margin="0,0,0,12"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Total Area -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Total area:" Margin="0,0,8,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" 
                                       Text="{Binding TotalRotationArea, StringFormat='{}{0:F2} ha'}"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,0,4"/>

                            <!-- Number of Fields -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Fields:" Margin="0,0,8,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" 
                                       Text="{Binding NumberOfFields}"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,0,4"/>

                            <!-- Years per Field -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Years/field:" Margin="0,0,8,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" 
                                       Text="{Binding RotationLength}"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,0,4"/>

                            <!-- Total Crop-Years -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Crop-years:" Margin="0,0,8,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" 
                                       Text="{Binding TotalCropYears}"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
