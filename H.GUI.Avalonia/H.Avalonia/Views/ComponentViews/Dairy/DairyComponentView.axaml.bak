        </StackPanel>
      </Border>

      <!-- Help Panel -->
      <Border Background="#E3F2FD" BorderBrush="#1976D2" BorderThickness="1" CornerRadius="8">
        <Border Padding="20">
          <StackPanel>
            <Grid ColumnDefinitions="Auto,*">
              <TextBlock Grid.Column="0" Text="??" FontSize="24" Margin="0,0,12,0"/>
              <StackPanel Grid.Column="1">
                <TextBlock Text="Understanding the Lifecycle Approach" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20" Text="This configuration method follows the natural flow of dairy cattle through their productive life. Instead of manually creating separate animal groups, you define your herd size and key parameters, and the system automatically calculates how many animals are in each lifecycle stage."/>
                <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20" Margin="0,12,0,0" FontWeight="SemiBold" Text="Benefits:"/>
                <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20" Margin="0,4,0,0" Text="• Reduces configuration errors by auto-calculating animal numbers"/>
                <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20" Margin="0,4,0,0" Text="• Ensures all lifecycle stages are accounted for"/>
                <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20" Margin="0,4,0,0" Text="• Provides a visual understanding of herd dynamics"/>
                <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20" Margin="0,4,0,0" Text="• Simplifies complex dairy operation modeling"/>
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>
      </Border>

    </StackPanel>
  </ScrollViewer>
  
</UserControl>
