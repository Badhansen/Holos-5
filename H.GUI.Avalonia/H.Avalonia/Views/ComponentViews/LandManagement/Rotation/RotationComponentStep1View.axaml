<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:field="clr-namespace:H.Avalonia.ViewModels.ComponentViews.LandManagement.Field"
             xmlns:rotation="clr-namespace:H.Avalonia.ViewModels.ComponentViews.LandManagement.Rotation"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="H.Avalonia.RotationComponentStep1View">

    <Design.DataContext>
        <rotation:RotationComponentViewModelDesign/>
    </Design.DataContext>

    <StackPanel>
        <StackPanel Classes="step-header">
            <!-- Step Badge -->
            <Border Classes="step-badge">
                <TextBlock Text="Step 1" Classes="step-badge-text"/>
            </Border>
            
            <!-- Step Description -->
            <TextBlock Text="Enter basic information for this crop rotation"
                       Classes="step-number-description"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </StackPanel>
</UserControl>
