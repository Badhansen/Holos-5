<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:rotation="clr-namespace:H.Avalonia.ViewModels.ComponentViews.LandManagement.Rotation"
			 xmlns:shared="clr-namespace:H.Avalonia.Views.ComponentViews.Shared"
			 xmlns:properties="clr-namespace:H.Avalonia.Infrastructure.Properties;assembly=H.Avalonia.Infrastructure"
			 xmlns:rotationViews="clr-namespace:H.Avalonia"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="H.Avalonia.Views.ComponentViews.LandManagement.Rotation.RotationComponentView">

	<Design.DataContext>
		<rotation:RotationComponentViewModelDesign/>
	</Design.DataContext>

	<Grid>
		<Grid.RowDefinitions>
			<!-- Title -->
			<RowDefinition Height="Auto"/>
			<!-- Advanced Options Toggle -->
			<RowDefinition Height="Auto"/>
			<!-- Content -->
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0">
			<!-- Title -->
			<TextBox Classes="view-title" Text="{Binding Path=SelectedRotationComponentDto.Name}"/>
			<Border Classes="title-underline"/>
		</StackPanel>

		<!-- Advanced Options Toggle Section -->
		<shared:AdvancedOptionsToggleView Grid.Row="1"
										  Margin="{StaticResource DefaultUserControlMargin}"
										  Title="Show Advanced Options"
										  Description="Display additional configuration options for detailed crop rotation management"
										  IsChecked="{Binding ShowAdvancedOptions, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"/>

		<!-- TODO: Add rotation component content here in Grid.Row="2" -->

		<ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
			<Grid>
				<Grid.RowDefinitions>
					<!-- Step 1 row -->
					<RowDefinition Height="Auto"/>

					<!-- Step 1 GridSplitter row -->
					<RowDefinition Height="Auto"/>

					<!-- Step 2 row - Auto height to accommodate timeline -->
					<RowDefinition Height="Auto"/>

					<!-- Step 2 GridSplitter row -->
					<RowDefinition Height="Auto"/>

					<!-- Step 3 row - Auto height to ensure visibility -->
					<RowDefinition Height="Auto"/>

				</Grid.RowDefinitions>

                <!-- Begin step 1 -->
                <Border Grid.Row="0"
                        Classes="step-container"
                        Margin="{StaticResource DefaultUserControlMargin}">
                    <rotationViews:RotationComponentStep1View/>
                </Border>
                <!-- End step 1 -->
			</Grid>
		</ScrollViewer>
	</Grid>
</UserControl>
