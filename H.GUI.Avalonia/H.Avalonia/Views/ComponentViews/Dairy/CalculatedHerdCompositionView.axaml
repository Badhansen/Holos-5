<UserControl xmlns="https://github.com/avaloniaui"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
           xmlns:dairy="clr-namespace:H.Avalonia.Views.ComponentViews.Dairy"
           xmlns:converters="clr-namespace:H.Avalonia.Converters"
           mc:Ignorable="d" d:DesignWidth="900"
           x:Class="H.Avalonia.Views.ComponentViews.Dairy.CalculatedHerdCompositionView">

<UserControl.Resources>
  <converters:BoolToBackgroundConverter x:Key="BoolToBackgroundConverter"/>
  <converters:BoolToBorderBrushConverter x:Key="BoolToBorderBrushConverter"/>
  <converters:BoolToBorderThicknessConverter x:Key="BoolToBorderThicknessConverter"/>
</UserControl.Resources>
  
<!-- Calculated Herd Composition Panel - Flow Rate Method Only -->
  <Border x:Name="MainContainerBorder"
          Classes="step-container" 
          Background="#E8F5E9" 
          BorderBrush="#43A047" 
          Margin="0,0,0,20">
    <StackPanel x:Name="MainStackPanel">
      <!-- Step Header -->
      <StackPanel x:Name="StepHeaderStackPanel"
                  Classes="step-header">
        <!-- Step Badge -->
        <Border Classes="step-badge" HorizontalAlignment="Left">
          <TextBlock Text="Step 2" Classes="step-badge-text"/>
        </Border>
        
        <!-- Title -->
        <TextBlock x:Name="HeaderTitleTextBlock"
                   Text="Select a Lifecycle Stage to Configure"
                   Classes="step-number-description"
                   Margin="0,8,0,0"/>
        
        <!-- Description -->
        <TextBlock x:Name="HeaderDescriptionTextBlock"
                   Text="Click on one of the stage cards below to begin editing its management practices in Step 3" 
                   FontSize="12"
                   Foreground="#666"
                   TextWrapping="Wrap"
                   Margin="0,8,0,0"/>
        
        <!-- Context Info -->
        <TextBlock x:Name="HeaderContextTextBlock"
                   Text="Steady-state population calculated from animals entering each stage per year" 
                   FontSize="11"
                   FontStyle="Italic"
                   Foreground="#999"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0"/>
      </StackPanel>
      
      <!-- Main Content with Cards and Calculations -->
      <StackPanel x:Name="MainContentStackPanel">
        <!-- Stage Cards Row with Integrated Calculations -->
        <Grid x:Name="StageCardsGrid"
              ColumnDefinitions="*,*,*,*,Auto">
          <!-- Calves -->
          <Button Grid.Column="0" 
                  Background="Transparent" 
                  BorderThickness="0" 
                  Padding="0"
                  Cursor="Hand"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch"
                  VerticalContentAlignment="Stretch"
                  Click="OnCalfCardClick">
            <Border x:Name="CalfStageBorder"
                    Background="{Binding IsCalfSelected, Converter={StaticResource BoolToBackgroundConverter}}"
                    BorderBrush="{Binding IsCalfSelected, Converter={StaticResource BoolToBorderBrushConverter}}"
                    BorderThickness="{Binding IsCalfSelected, Converter={StaticResource BoolToBorderThicknessConverter}}"
                    CornerRadius="8" 
                    Padding="12" 
                    Margin="4">
              <StackPanel x:Name="CalfContentStackPanel">
                <TextBlock x:Name="CalfTitleTextBlock"
                           Text="CALF" 
                           FontSize="14" 
                           FontWeight="Bold" 
                           Foreground="#1976D2" 
                           HorizontalAlignment="Center" 
                           Margin="0,4,0,8"/>
                
                <TextBlock x:Name="CalfCountTextBlock"
                           Text="{Binding SelectedDairyComponentDto.SteadyStateCalves, StringFormat='{}{0} animals'}" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="#1976D2" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                
                <TextBlock x:Name="CalfDaysTextBlock"
                           Text="120 days in stage" 
                           FontSize="10" 
                           Foreground="#666" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>
                
                <!-- Integrated Calculation -->
                <Border x:Name="CalfCalculationDetailsBorder"
                        Background="#E3F2FD" 
                        BorderBrush="#1976D2" 
                        BorderThickness="1"
                        CornerRadius="4" 
                        Padding="8"
                        IsVisible="{Binding ShowAdvancedOptions, RelativeSource={RelativeSource AncestorType={x:Type dairy:DairyComponentView}}}">
                  <StackPanel x:Name="CalfCalculationStackPanel">
                    <TextBlock x:Name="CalfInputLabelTextBlock"
                               Text="Input:" 
                               FontSize="9" 
                               FontWeight="SemiBold" 
                               Foreground="#1976D2"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="CalfInputValueTextBlock"
                               TextWrapping="Wrap" 
                               FontSize="10" 
                               Foreground="#666"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6">
                      <Run Text="{Binding SelectedDairyComponentDto.CalvesEnteringPerYear, StringFormat='{}{0}'}" FontWeight="Bold" Foreground="#1976D2"/>
                      <Run Text=" calves/yr"/>
                    </TextBlock>
                    
                    <TextBlock x:Name="CalfFormulaLabelTextBlock"
                               Text="Formula:" 
                               FontSize="9" 
                               FontWeight="SemiBold" 
                               Foreground="#1976D2"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="CalfFormulaTextBlock"
                               TextWrapping="Wrap" 
                               FontSize="9" 
                               Foreground="#666"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               LineHeight="13">
                      <Run Text="{Binding SelectedDairyComponentDto.CalvesEnteringPerYear, StringFormat='{}{0}'}" FontWeight="SemiBold"/>
                      <Run Text=" * 0.329"/>
                      <LineBreak/>
                      <Run Text="= "/>
                      <Run Text="{Binding SelectedDairyComponentDto.SteadyStateCalves}" FontWeight="Bold" Foreground="#1976D2"/>
                    </TextBlock>
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>
          </Button>
          
          
          <!-- Heifers -->
          <Button Grid.Column="1" 
                  Background="Transparent" 
                  BorderThickness="0" 
                  Padding="0"
                  Cursor="Hand"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch"
                  VerticalContentAlignment="Stretch"
                  Click="OnHeiferCardClick">
            <Border x:Name="HeiferStageBorder"
                    Background="{Binding IsHeiferSelected, Converter={StaticResource BoolToBackgroundConverter}}"
                    BorderBrush="{Binding IsHeiferSelected, Converter={StaticResource BoolToBorderBrushConverter}}"
                    BorderThickness="{Binding IsHeiferSelected, Converter={StaticResource BoolToBorderThicknessConverter}}"
                    CornerRadius="8" 
                    Padding="12" 
                    Margin="4">
            <StackPanel x:Name="HeiferContentStackPanel">
              <TextBlock x:Name="HeiferTitleTextBlock"
                         Text="HEIFER" 
                         FontSize="14" 
                         FontWeight="Bold" 
                         Foreground="#7B1FA2" 
                         HorizontalAlignment="Center" 
                         Margin="0,4,0,8"/>
              
              <TextBlock x:Name="HeiferCountTextBlock"
                         Text="{Binding SelectedDairyComponentDto.SteadyStateHeifers, StringFormat='{}{0} animals'}" 
                         FontSize="20" 
                         FontWeight="Bold" 
                         Foreground="#7B1FA2" 
                         HorizontalAlignment="Center"
                         Margin="0,0,0,8"/>
              
              <TextBlock x:Name="HeiferDaysTextBlock"
                         Text="608 days in stage" 
                         FontSize="10" 
                         Foreground="#666" 
                         HorizontalAlignment="Center"
                         Margin="0,0,0,12"/>
              
              <!-- Integrated Calculation -->
              <Border x:Name="HeiferCalculationDetailsBorder"
                      Background="#F3E5F5" 
                      BorderBrush="#7B1FA2" 
                      BorderThickness="1"
                      CornerRadius="4" 
                      Padding="8"
                      IsVisible="{Binding ShowAdvancedOptions, RelativeSource={RelativeSource AncestorType={x:Type dairy:DairyComponentView}}}">
                <StackPanel x:Name="HeiferCalculationStackPanel">
                  <TextBlock x:Name="HeiferInputLabelTextBlock"
                             Text="Input:" 
                             FontSize="9" 
                             FontWeight="SemiBold" 
                             Foreground="#7B1FA2"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,4"/>
                  <TextBlock x:Name="HeiferInputValueTextBlock"
                             TextWrapping="Wrap" 
                             FontSize="10" 
                             Foreground="#666"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,6">
                    <Run Text="{Binding SelectedDairyComponentDto.HeifersEnteringPerYear, StringFormat='{}{0}'}" FontWeight="Bold" Foreground="#7B1FA2"/>
                    <Run Text=" heifers/yr"/>
                  </TextBlock>
                  
                  <TextBlock x:Name="HeiferFormulaLabelTextBlock"
                             Text="Formula:" 
                             FontSize="9" 
                             FontWeight="SemiBold" 
                             Foreground="#7B1FA2"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,4"/>
                  <TextBlock x:Name="HeiferFormulaTextBlock"
                             TextWrapping="Wrap" 
                             FontSize="9" 
                             Foreground="#666"
                             HorizontalAlignment="Center"
                             TextAlignment="Center"
                             LineHeight="13">
                    <Run Text="{Binding SelectedDairyComponentDto.HeifersEnteringPerYear, StringFormat='{}{0}'}" FontWeight="SemiBold"/>
                    <Run Text=" * 1.666"/>
                    <LineBreak/>
                    <Run Text="= "/>
                    <Run Text="{Binding SelectedDairyComponentDto.SteadyStateHeifers}" FontWeight="Bold" Foreground="#7B1FA2"/>
                  </TextBlock>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>
        </Button>
          
          
          <!-- Lactating -->
          <Button Grid.Column="2" 
                  Background="Transparent" 
                  BorderThickness="0" 
                  Padding="0"
                  Cursor="Hand"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch"
                  VerticalContentAlignment="Stretch"
                  Click="OnLactatingCardClick">
            <Border x:Name="LactatingStageBorder"
                    Background="{Binding IsLactatingSelected, Converter={StaticResource BoolToBackgroundConverter}}"
                    BorderBrush="{Binding IsLactatingSelected, Converter={StaticResource BoolToBorderBrushConverter}}"
                    BorderThickness="{Binding IsLactatingSelected, Converter={StaticResource BoolToBorderThicknessConverter}}"
                    CornerRadius="8" 
                    Padding="12" 
                    Margin="4">
            <StackPanel x:Name="LactatingContentStackPanel">
              <TextBlock x:Name="LactatingTitleTextBlock"
                         Text="LACTATING" 
                         FontSize="14" 
                         FontWeight="Bold" 
                         Foreground="#388E3C" 
                         HorizontalAlignment="Center" 
                         Margin="0,4,0,8"/>
              
              <TextBlock x:Name="LactatingCountTextBlock"
                         Text="{Binding SelectedDairyComponentDto.SteadyStateLactating, StringFormat='{}{0} animals'}" 
                         FontSize="20" 
                         FontWeight="Bold" 
                         Foreground="#388E3C" 
                         HorizontalAlignment="Center"
                         Margin="0,0,0,8"/>
              
              <TextBlock x:Name="LactatingDaysTextBlock"
                         Text="305 days in stage" 
                         FontSize="10" 
                         Foreground="#666" 
                         HorizontalAlignment="Center"
                         Margin="0,0,0,12"/>
              
              <!-- Integrated Calculation -->
              <Border x:Name="LactatingCalculationDetailsBorder"
                      Background="#E8F5E9" 
                      BorderBrush="#388E3C" 
                      BorderThickness="1"
                      CornerRadius="4" 
                      Padding="8"
                      IsVisible="{Binding ShowAdvancedOptions, RelativeSource={RelativeSource AncestorType={x:Type dairy:DairyComponentView}}}">
                <StackPanel x:Name="LactatingCalculationStackPanel">
                  <TextBlock x:Name="LactatingInputLabelTextBlock"
                             Text="Input:" 
                             FontSize="9" 
                             FontWeight="SemiBold" 
                             Foreground="#388E3C"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,4"/>
                  <TextBlock x:Name="LactatingInputValueTextBlock"
                             TextWrapping="Wrap" 
                             FontSize="10" 
                             Foreground="#666"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,6">
                    <Run Text="{Binding SelectedDairyComponentDto.LactatingCowsEnteringPerYear, StringFormat='{}{0}'}" FontWeight="Bold" Foreground="#388E3C"/>
                    <Run Text=" cows/yr"/>
                  </TextBlock>
                  
                  <TextBlock x:Name="LactatingFormulaLabelTextBlock"
                             Text="Formula:" 
                             FontSize="9" 
                             FontWeight="SemiBold" 
                             Foreground="#388E3C"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,4"/>
                  <TextBlock x:Name="LactatingFormulaTextBlock"
                             TextWrapping="Wrap" 
                             FontSize="9" 
                             Foreground="#666"
                             HorizontalAlignment="Center"
                             TextAlignment="Center"
                             LineHeight="13">
                    <Run Text="{Binding SelectedDairyComponentDto.LactatingCowsEnteringPerYear, StringFormat='{}{0}'}" FontWeight="SemiBold"/>
                    <Run Text=" * 0.836"/>
                    <LineBreak/>
                    <Run Text="= "/>
                    <Run Text="{Binding SelectedDairyComponentDto.SteadyStateLactating}" FontWeight="Bold" Foreground="#388E3C"/>
                  </TextBlock>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>
        </Button>
          
          
          <!-- Dry -->
          <Button Grid.Column="3" 
                  Background="Transparent" 
                  BorderThickness="0" 
                  Padding="0"
                  Cursor="Hand"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch"
                  VerticalContentAlignment="Stretch"
                  Click="OnDryCardClick">
            <Border x:Name="DryStageBorder"
                    Background="{Binding IsDrySelected, Converter={StaticResource BoolToBackgroundConverter}}"
                    BorderBrush="{Binding IsDrySelected, Converter={StaticResource BoolToBorderBrushConverter}}"
                    BorderThickness="{Binding IsDrySelected, Converter={StaticResource BoolToBorderThicknessConverter}}"
                    CornerRadius="8" 
                    Padding="12" 
                    Margin="4">
            <StackPanel x:Name="DryContentStackPanel">
              <TextBlock x:Name="DryTitleTextBlock"
                         Text="DRY" 
                         FontSize="14" 
                         FontWeight="Bold" 
                         Foreground="#F57C00" 
                         HorizontalAlignment="Center" 
                         Margin="0,4,0,8"/>
              
              <TextBlock x:Name="DryCountTextBlock"
                         Text="{Binding SelectedDairyComponentDto.SteadyStateDry, StringFormat='{}{0} animals'}" 
                         FontSize="20" 
                         FontWeight="Bold" 
                         Foreground="#F57C00" 
                         HorizontalAlignment="Center"
                         Margin="0,0,0,8"/>
              
              <TextBlock x:Name="DryDaysTextBlock"
                         Text="{Binding SelectedDairyComponentDto.DryPeriodDays, StringFormat='{}{0} days in stage'}" 
                         FontSize="10" 
                         Foreground="#666" 
                         HorizontalAlignment="Center"
                         Margin="0,0,0,12"/>
              
              <!-- Integrated Calculation -->
              <Border x:Name="DryCalculationDetailsBorder"
                      Background="#FFF3E0" 
                      BorderBrush="#F57C00" 
                      BorderThickness="1"
                      CornerRadius="4" 
                      Padding="8"
                      IsVisible="{Binding ShowAdvancedOptions, RelativeSource={RelativeSource AncestorType={x:Type dairy:DairyComponentView}}}">
                <StackPanel x:Name="DryCalculationStackPanel">
                  <TextBlock x:Name="DryInputLabelTextBlock"
                             Text="Input:" 
                             FontSize="9" 
                             FontWeight="SemiBold" 
                             Foreground="#F57C00"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,4"/>
                  <TextBlock x:Name="DryInputValueTextBlock"
                             TextWrapping="Wrap" 
                             FontSize="10" 
                             Foreground="#666"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,6">
                    <Run Text="{Binding SelectedDairyComponentDto.DryCowsEnteringPerYear, StringFormat='{}{0}'}" FontWeight="Bold" Foreground="#F57C00"/>
                    <Run Text=" cows/yr"/>
                  </TextBlock>
                  
                  <TextBlock x:Name="DryFormulaLabelTextBlock"
                             Text="Formula:" 
                             FontSize="9" 
                             FontWeight="SemiBold" 
                             Foreground="#F57C00"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,4"/>
                  <TextBlock x:Name="DryFormulaTextBlock"
                             TextWrapping="Wrap" 
                             FontSize="9" 
                             Foreground="#666"
                             HorizontalAlignment="Center"
                             TextAlignment="Center"
                             LineHeight="13">
                    <Run Text="{Binding SelectedDairyComponentDto.DryCowsEnteringPerYear, StringFormat='{}{0}'}" FontWeight="SemiBold"/>
                    <Run Text=" * ("/>
                    <Run Text="{Binding SelectedDairyComponentDto.DryPeriodDays, StringFormat='{}{0}'}"/>
                    <Run Text="/365)"/>
                    <LineBreak/>
                    <Run Text="= "/>
                    <Run Text="{Binding SelectedDairyComponentDto.SteadyStateDry}" FontWeight="Bold" Foreground="#F57C00"/>
                  </TextBlock>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>
        </Button>
          
          <!-- Total -->
          <Border x:Name="TotalBorder"
                  Grid.Column="4" 
                  Background="#43A047" 
                  CornerRadius="8" 
                  Padding="16" 
                  Margin="4"
                  VerticalAlignment="Stretch">
            <StackPanel x:Name="TotalContentStackPanel"
                        VerticalAlignment="Center">
              <TextBlock x:Name="TotalTitleTextBlock"
                         Text="TOTAL" 
                         FontSize="14" 
                         FontWeight="Bold" 
                         Foreground="White" 
                         HorizontalAlignment="Center" 
                         Margin="0,0,0,4"/>
              <TextBlock x:Name="TotalCountTextBlock"
                         Text="{Binding SelectedDairyComponentDto.TotalSteadyStateHerdSize, StringFormat='{}{0}'}" 
                         FontSize="24" 
                         FontWeight="Bold" 
                         Foreground="White" 
                         HorizontalAlignment="Center"
                         Margin="0,0,0,2"/>
              <TextBlock x:Name="TotalLabelTextBlock"
                         Text="animals" 
                         FontSize="10" 
                         Foreground="White" 
                         HorizontalAlignment="Center"/>
            </StackPanel>
          </Border>
        </Grid>
      </StackPanel>
      
      
      <!-- Overall Explanation -->
      <Border x:Name="OverallExplanationBorder"
              Background="White" 
              BorderBrush="#43A047" 
              BorderThickness="2" 
              CornerRadius="6" 
              Padding="16" 
              Margin="4,12,4,4"
              IsVisible="{Binding ShowAdvancedOptions, RelativeSource={RelativeSource AncestorType={x:Type dairy:DairyComponentView}}}">
        <StackPanel x:Name="ExplanationContentStackPanel">
          <TextBlock x:Name="ExplanationHeaderTextBlock"
                     Text="How These Numbers Are Calculated" 
                     FontSize="13" 
                     FontWeight="Bold" 
                     Foreground="#43A047"
                     Margin="0,0,0,12"/>
          
          <TextBlock x:Name="ExplanationIntroTextBlock"
                     TextWrapping="Wrap" 
                     FontSize="11" 
                     Foreground="#666" 
                     LineHeight="18"
                     Margin="0,0,0,12">
            <Run Text="The numbers shown above represent the " FontWeight="SemiBold"/>
            <Run Text="steady-state population" FontWeight="Bold" Foreground="#43A047"/>
            <Run Text=" — how many animals will be in each stage at any given moment in a continuous-flow dairy operation."/>
          </TextBlock>
          
          <Border x:Name="FormulaBorder"
                  Background="#F1F8E9" 
                  BorderBrush="#8BC34A" 
                  BorderThickness="1"
                  CornerRadius="4" 
                  Padding="12" 
                  Margin="0,0,0,12">
            <StackPanel x:Name="FormulaStackPanel">
              <TextBlock x:Name="FormulaHeaderTextBlock"
                         Text="The Formula" 
                         FontSize="12" 
                         FontWeight="SemiBold" 
                         Foreground="#558B2F"
                         Margin="0,0,0,8"/>
              <TextBlock x:Name="FormulaTextBlock"
                         TextWrapping="Wrap" 
                         FontSize="11" 
                         Foreground="#666"
                         LineHeight="18">
                <Run Text="Steady-State Population = " FontWeight="SemiBold"/>
                <Run Text="(Animals Entering Per Year)" FontWeight="Bold" Foreground="#1976D2"/>
                <Run Text=" * "/>
                <Run Text="(Days in Stage / 365)" FontWeight="Bold" Foreground="#F57C00"/>
              </TextBlock>
            </StackPanel>
          </Border>
          
          <TextBlock x:Name="ExampleHeaderTextBlock"
                     Text="Example Walkthrough: Calf Stage" 
                     FontSize="12" 
                     FontWeight="SemiBold" 
                     Foreground="#1976D2"
                     Margin="0,0,0,8"/>
          
          <StackPanel x:Name="ExampleStepsStackPanel"
                      Margin="12,0,0,12">
            <TextBlock x:Name="ExampleStep1TextBlock"
                       TextWrapping="Wrap" 
                       FontSize="11" 
                       Foreground="#666" 
                       LineHeight="18"
                       Margin="0,0,0,6">
              <Run Text="1. You entered: " FontWeight="SemiBold"/>
              <Run Text="{Binding SelectedDairyComponentDto.CalvesEnteringPerYear, StringFormat='{}{0} calves'}" FontWeight="Bold" Foreground="#1976D2"/>
              <Run Text=" are born per year"/>
            </TextBlock>
            
            <TextBlock x:Name="ExampleStep2TextBlock"
                       TextWrapping="Wrap" 
                       FontSize="11" 
                       Foreground="#666" 
                       LineHeight="18"
                       Margin="0,0,0,6">
              <Run Text="2. Calves stay in this stage for: " FontWeight="SemiBold"/>
              <Run Text="120 days" FontWeight="Bold" Foreground="#F57C00"/>
              <Run Text=" (from birth to weaning)"/>
            </TextBlock>
            
            <TextBlock x:Name="ExampleStep3TextBlock"
                       TextWrapping="Wrap" 
                       FontSize="11" 
                       Foreground="#666" 
                       LineHeight="18"
                       Margin="0,0,0,6">
              <Run Text="3. Calculate the ratio: " FontWeight="SemiBold"/>
              <Run Text="120 / 365 = 0.329" FontWeight="Bold"/>
              <Run Text=" (about one-third of a year)"/>
            </TextBlock>
            
            <TextBlock x:Name="ExampleStep4TextBlock"
                       TextWrapping="Wrap" 
                       FontSize="11" 
                       Foreground="#666" 
                       LineHeight="18">
              <Run Text="4. Multiply: " FontWeight="SemiBold"/>
              <Run Text="{Binding SelectedDairyComponentDto.CalvesEnteringPerYear, StringFormat='{}{0}'}" FontWeight="Bold" Foreground="#1976D2"/>
              <Run Text=" * 0.329 = "/>
              <Run Text="{Binding SelectedDairyComponentDto.SteadyStateCalves}" FontWeight="Bold" Foreground="#43A047" FontSize="12"/>
              <Run Text=" calves at any time"/>
            </TextBlock>
          </StackPanel>
          
          <Border x:Name="KeyInsightBorder"
                  Background="#FFF3E0" 
                  BorderBrush="#FF9800" 
                  BorderThickness="1"
                  CornerRadius="4" 
                  Padding="12">
            <StackPanel x:Name="KeyInsightStackPanel">
              <TextBlock x:Name="KeyInsightHeaderTextBlock"
                         Text="Key Insight" 
                         FontSize="12" 
                         FontWeight="SemiBold" 
                         Foreground="#E65100"
                         Margin="0,0,0,8"/>
              <TextBlock x:Name="KeyInsightTextBlock"
                         TextWrapping="Wrap" 
                         FontSize="11" 
                         Foreground="#666"
                         LineHeight="18">
                <Run Text="Even though "/>
                <Run Text="{Binding SelectedDairyComponentDto.CalvesEnteringPerYear, StringFormat='{}{0} calves'}" FontWeight="Bold"/>
                <Run Text=" are born each year, only "/>
                <Run Text="{Binding SelectedDairyComponentDto.SteadyStateCalves}" FontWeight="Bold" Foreground="#43A047"/>
                <Run Text=" calves are present at any given moment because they only spend "/>
                <Run Text="120 days" FontWeight="Bold"/>
                <Run Text=" (one-third of a year) in this stage before moving to the heifer stage. This continuous flow creates the steady-state population."/>
              </TextBlock>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>
    </StackPanel>
  </Border>
  
</UserControl>