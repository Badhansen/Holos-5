<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:avalonia="clr-namespace:H.Avalonia"
             xmlns:properties="clr-namespace:H.Core.Properties;assembly=H.Core"
             xmlns:field="clr-namespace:H.Avalonia.Views.ComponentViews.LandManagement.Field"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="950"
             x:Class="H.Avalonia.Views.ComponentViews.LandManagement.Field.SelectedCropTabView">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section with Advanced Toggle -->
        <StackPanel Grid.Row="0" Margin="10,8,0,20">
            <!-- Step Header Row -->
            <StackPanel Classes="step-header" Margin="0,0,0,16">
                <!-- Step Badge -->
                <Border Classes="step-badge">
                    <TextBlock Text="Step 3" Classes="step-badge-text"/>
                </Border>
                
                <!-- Step Description -->
                <TextBlock Text="Define management practices for your selected crop"
                           Classes="step-number-description"
                           VerticalAlignment="Center"/>
            </StackPanel>
            
            <!-- Advanced Options Toggle Section -->
            <Border Background="#F8F9FA" CornerRadius="8" Padding="16,12" BorderBrush="#E9ECEF" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Show Advanced Options" 
                                  FontSize="15" FontWeight="SemiBold" 
                                  Foreground="#495057" Margin="0,0,0,2"/>
                        <TextBlock Text="Display additional configuration options for detailed crop management" 
                                  FontSize="11" Foreground="#6C757D" 
                                  FontStyle="Italic"/>
                    </StackPanel>
                    
                    <ToggleSwitch Grid.Column="1" 
                                Name="ShowAdvancedOptionsToggle"
                                VerticalAlignment="Center"
                                Margin="12,0,0,0"
                                OffContent="Basic"
                                OnContent="Advanced"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- Card-based Content Section -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="20" Margin="10">
                
                <!-- General Information Card (Always Visible) -->
                <Border Classes="step-card">
                    <StackPanel>
                        <!-- Card Header -->
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="{x:Static properties:Resources.TabHeaderGeneral}" 
                                      FontSize="18" FontWeight="Bold" 
                                      Foreground="#2C3E50" Margin="0,0,0,4"/>
                            <TextBlock Text="Configure basic crop parameters including yield and irrigation" 
                                      FontSize="12" Foreground="Gray" 
                                      FontStyle="Italic"/>
                        </StackPanel>
                        
                        <!-- Card Content -->
                        <field:SelectedCropGeneralTabView/>
                    </StackPanel>
                </Border>

                <!-- Residues Information Card (Advanced Only) -->
                <Border Classes="step-card" 
                       IsVisible="{Binding #ShowAdvancedOptionsToggle.IsChecked}"
                       BorderBrush="#FF8C00" 
                       BorderThickness="3,3,3,3">
                    <StackPanel>
                        <!-- Card Header with Advanced Indicator -->
                        <StackPanel Margin="0,0,0,20">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0"
                                          Text="{x:Static properties:Resources.TabHeaderResidues}" 
                                          FontSize="18" FontWeight="Bold" 
                                          Foreground="#2C3E50"/>
                                
                                <!-- Small Advanced Indicator -->
                                <Border Grid.Column="1" 
                                       Background="#FF8C00" 
                                       CornerRadius="10" 
                                       Padding="6,2"
                                       VerticalAlignment="Center">
                                    <TextBlock Text="ADVANCED" 
                                              FontSize="8" 
                                              FontWeight="Bold" 
                                              Foreground="White" 
                                              HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                            
                            <TextBlock Text="Set biomass coefficients for different crop components" 
                                      FontSize="12" Foreground="Gray" 
                                      FontStyle="Italic"/>
                        </StackPanel>
                        
                        <!-- Card Content -->
                        <field:SelectedCropResiduesTabView/>
                    </StackPanel>
                </Border>

                <!-- Fertilizer Information Card (Advanced Only) -->
                <Border Classes="step-card" 
                       IsVisible="{Binding #ShowAdvancedOptionsToggle.IsChecked}"
                       BorderBrush="#FF8C00" 
                       BorderThickness="3,3,3,3">
                    <StackPanel>
                        <!-- Card Header with Advanced Indicator -->
                        <StackPanel Margin="0,0,0,20">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0"
                                          Text="{x:Static properties:Resources.TabHeaderFertilizer}" 
                                          FontSize="18" FontWeight="Bold" 
                                          Foreground="#2C3E50"/>
                                
                                <!-- Small Advanced Indicator -->
                                <Border Grid.Column="1" 
                                       Background="#FF8C00" 
                                       CornerRadius="10" 
                                       Padding="6,2"
                                       VerticalAlignment="Center">
                                    <TextBlock Text="ADVANCED" 
                                              FontSize="8" 
                                              FontWeight="Bold" 
                                              Foreground="White" 
                                              HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                            
                            <TextBlock Text="Configure fertilizer application settings and schedules" 
                                      FontSize="12" Foreground="Gray" 
                                      FontStyle="Italic"/>
                        </StackPanel>
                        
                        <!-- Card Content -->
                        <Border Background="#F8F9FA" CornerRadius="8" Padding="20" BorderBrush="#E9ECEF" BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                                <TextBlock Text="??" FontSize="48" HorizontalAlignment="Center" Opacity="0.7"/>
                                <TextBlock Text="Fertilizer Configuration" 
                                          FontSize="16" FontWeight="SemiBold" 
                                          HorizontalAlignment="Center" Foreground="#6C757D"/>
                                <TextBlock Text="This section will be implemented in a future update" 
                                          FontSize="12" HorizontalAlignment="Center" 
                                          Foreground="#6C757D" FontStyle="Italic"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Placeholder for Future Advanced Cards -->
                <!-- Additional advanced cards can be added here with the same pattern:
                     IsVisible="{Binding #ShowAdvancedOptionsToggle.IsChecked}" and orange header style -->
                
            </StackPanel>
        </ScrollViewer>
        
    </Grid>
</UserControl>
