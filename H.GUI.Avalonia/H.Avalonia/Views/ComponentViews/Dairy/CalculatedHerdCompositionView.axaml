<UserControl xmlns="https://github.com/avaloniaui"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
           xmlns:dairy="clr-namespace:H.Avalonia.Views.ComponentViews.Dairy"
           xmlns:dairyVm="clr-namespace:H.Avalonia.ViewModels.ComponentViews.Dairy"
           xmlns:converters="clr-namespace:H.Avalonia.Converters"
           mc:Ignorable="d" d:DesignWidth="900"
           x:Class="H.Avalonia.Views.ComponentViews.Dairy.CalculatedHerdCompositionView">

<Design.DataContext>
  <dairyVm:DairyComponentViewModelDesign/>
</Design.DataContext>

<UserControl.Resources>
  <converters:BoolToBackgroundConverter x:Key="BoolToBackgroundConverter"/>
  <converters:BoolToBorderBrushConverter x:Key="BoolToBorderBrushConverter"/>
  <converters:BoolToBorderThicknessConverter x:Key="BoolToBorderThicknessConverter"/>
</UserControl.Resources>
  
<!-- Calculated Herd Composition Panel - Flow Rate Method Only -->
  <Border x:Name="MainContainerBorder"
          Classes="step-container" 
          Background="#E8F5E9" 
          BorderBrush="#43A047" 
          Margin="0,0,0,20">
    <StackPanel x:Name="MainStackPanel">
      <!-- Step Header -->
      <StackPanel x:Name="StepHeaderStackPanel"
                  Orientation="Vertical"
                  Classes="step-header">
        <!-- Step Badge -->
        <Border Classes="step-badge" HorizontalAlignment="Left">
          <TextBlock Text="Step 2" Classes="step-badge-text"/>
        </Border>
        
        <!-- Title -->
        <TextBlock x:Name="HeaderTitleTextBlock"
                   Text="Select a Lifecycle Stage to Configure"
                   Classes="step-number-description"
                   Margin="0,12,0,0"/>
        
        <!-- Description -->
        <TextBlock x:Name="HeaderDescriptionTextBlock"
                   Text="Click on a stage card below to configure its management practices in Step 3" 
                   FontSize="13"
                   Foreground="#555"
                   TextWrapping="Wrap"
                   Margin="0,12,0,0"/>
      </StackPanel>
      
      <!-- Main Content with Cards and Calculations -->
      <StackPanel x:Name="MainContentStackPanel">
        <!-- Stage Cards Row with Integrated Calculations -->
        <Grid x:Name="StageCardsGrid"
              ColumnDefinitions="*,*,*,*,Auto">
          <!-- Calves -->
          <Button Grid.Column="0" 
                  Background="Transparent" 
                  BorderThickness="0" 
                  Padding="0"
                  Cursor="Hand"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch"
                  VerticalContentAlignment="Stretch"
                  Click="OnCalfCardClick">
            <Border x:Name="CalfStageBorder"
                    Background="{Binding IsCalfSelected, Converter={StaticResource BoolToBackgroundConverter}}"
                    BorderBrush="{Binding IsCalfSelected, Converter={StaticResource BoolToBorderBrushConverter}}"
                    BorderThickness="{Binding IsCalfSelected, Converter={StaticResource BoolToBorderThicknessConverter}}"
                    CornerRadius="8" 
                    Padding="12" 
                    Margin="4">
              <StackPanel x:Name="CalfContentStackPanel">
                <TextBlock x:Name="CalfTitleTextBlock"
                           Text="CALF" 
                           FontSize="14" 
                           FontWeight="Bold" 
                           Foreground="#1976D2" 
                           HorizontalAlignment="Center" 
                           Margin="0,4,0,8"/>
                
                <TextBlock x:Name="CalfCountTextBlock"
                           Text="{Binding SelectedDairyComponentDto.SteadyStateCalves, StringFormat='{}{0} animals'}" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="#1976D2" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                
                <TextBlock x:Name="CalfDaysTextBlock"
                           Text="{Binding SelectedDairyComponentDto.CalfStageDurationDays, StringFormat='{}{0} days in stage'}" 
                           FontSize="10" 
                           Foreground="#666" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>
                
                <!-- Integrated Calculation -->
                <Border x:Name="CalfCalculationDetailsBorder"
                        Background="#E3F2FD" 
                        BorderBrush="#1976D2" 
                        BorderThickness="1"
                        CornerRadius="4" 
                        Padding="8"
                        IsVisible="{Binding ShowAdvancedOptions, RelativeSource={RelativeSource AncestorType={x:Type dairy:DairyComponentView}}}">
                  <StackPanel x:Name="CalfCalculationStackPanel">
                    <TextBlock x:Name="CalfInputLabelTextBlock"
                               Text="User Input:" 
                               FontSize="9" 
                               FontWeight="SemiBold" 
                               Foreground="#1976D2"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="CalfInputValueTextBlock"
                               TextWrapping="Wrap" 
                               FontSize="10" 
                               Foreground="#666"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6">
                      <Run Text="{Binding SelectedDairyComponentDto.SteadyStateCalves, StringFormat='{}{0}'}" FontWeight="Bold" Foreground="#1976D2"/>
                      <Run Text=" animals present"/>
                    </TextBlock>
                    
                    <TextBlock x:Name="CalfFormulaLabelTextBlock"
                               Text="Calculated Flow Rate:" 
                               FontSize="9" 
                               FontWeight="SemiBold" 
                               Foreground="#1976D2"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="CalfFormulaTextBlock"
                               TextWrapping="Wrap" 
                               FontSize="9" 
                               Foreground="#666"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               LineHeight="13">
                      <Run Text="{Binding SelectedDairyComponentDto.SteadyStateCalves, StringFormat='{}{0}'}" FontWeight="SemiBold"/>
                      <Run Text=" / (120/365)"/>
                      <LineBreak/>
                      <Run Text="= "/>
                      <Run Text="{Binding SelectedDairyComponentDto.CalvesEnteringPerYear}" FontWeight="Bold" Foreground="#1976D2"/>
                      <Run Text=" entering/yr"/>
                    </TextBlock>
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>
          </Button>
          
          
          <!-- Heifers -->
          <Button Grid.Column="1" 
                  Background="Transparent" 
                  BorderThickness="0" 
                  Padding="0"
                  Cursor="Hand"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch"
                  VerticalContentAlignment="Stretch"
                  Click="OnHeiferCardClick">
            <Border x:Name="HeiferStageBorder"
                    Background="{Binding IsHeiferSelected, Converter={StaticResource BoolToBackgroundConverter}}"
                    BorderBrush="{Binding IsHeiferSelected, Converter={StaticResource BoolToBorderBrushConverter}}"
                    BorderThickness="{Binding IsHeiferSelected, Converter={StaticResource BoolToBorderThicknessConverter}}"
                    CornerRadius="8" 
                    Padding="12" 
                    Margin="4">
            <StackPanel x:Name="HeiferContentStackPanel">
              <TextBlock x:Name="HeiferTitleTextBlock"
                         Text="HEIFER" 
                         FontSize="14" 
                         FontWeight="Bold" 
                         Foreground="#7B1FA2" 
                         HorizontalAlignment="Center" 
                         Margin="0,4,0,8"/>
              
              <TextBlock x:Name="HeiferCountTextBlock"
                         Text="{Binding SelectedDairyComponentDto.SteadyStateHeifers, StringFormat='{}{0} animals'}" 
                         FontSize="20" 
                         FontWeight="Bold" 
                         Foreground="#7B1FA2" 
                         HorizontalAlignment="Center"
                         Margin="0,0,0,8"/>
              
              <TextBlock x:Name="HeiferDaysTextBlock"
                         Text="{Binding SelectedDairyComponentDto.HeiferStageDurationDays, StringFormat='{}{0} days in stage'}" 
                         FontSize="10" 
                         Foreground="#666" 
                         HorizontalAlignment="Center"
                         Margin="0,0,0,12"/>
              
              <!-- Integrated Calculation -->
              <Border x:Name="HeiferCalculationDetailsBorder"
                      Background="#F3E5F5" 
                      BorderBrush="#7B1FA2" 
                      BorderThickness="1"
                      CornerRadius="4" 
                      Padding="8"
                      IsVisible="{Binding ShowAdvancedOptions, RelativeSource={RelativeSource AncestorType={x:Type dairy:DairyComponentView}}}">
                <StackPanel x:Name="HeiferCalculationStackPanel">
                  <TextBlock x:Name="HeiferInputLabelTextBlock"
                             Text="User Input:" 
                             FontSize="9" 
                             FontWeight="SemiBold" 
                             Foreground="#7B1FA2"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,4"/>
                  <TextBlock x:Name="HeiferInputValueTextBlock"
                             TextWrapping="Wrap" 
                             FontSize="10" 
                             Foreground="#666"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,6">
                    <Run Text="{Binding SelectedDairyComponentDto.SteadyStateHeifers, StringFormat='{}{0}'}" FontWeight="Bold" Foreground="#7B1FA2"/>
                    <Run Text=" animals present"/>
                  </TextBlock>
                  
                  <TextBlock x:Name="HeiferFormulaLabelTextBlock"
                             Text="Calculated Flow Rate:" 
                             FontSize="9" 
                             FontWeight="SemiBold" 
                             Foreground="#7B1FA2"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,4"/>
                  <TextBlock x:Name="HeiferFormulaTextBlock"
                             TextWrapping="Wrap" 
                             FontSize="9" 
                             Foreground="#666"
                             HorizontalAlignment="Center"
                             TextAlignment="Center"
                             LineHeight="13">
                    <Run Text="{Binding SelectedDairyComponentDto.SteadyStateHeifers, StringFormat='{}{0}'}" FontWeight="SemiBold"/>
                    <Run Text=" / (608/365)"/>
                    <LineBreak/>
                    <Run Text="= "/>
                    <Run Text="{Binding SelectedDairyComponentDto.HeifersEnteringPerYear}" FontWeight="Bold" Foreground="#7B1FA2"/>
                    <Run Text=" entering/yr"/>
                  </TextBlock>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>
        </Button>
          
          
          <!-- Lactating -->
          <Button Grid.Column="2" 
                  Background="Transparent" 
                  BorderThickness="0" 
                  Padding="0"
                  Cursor="Hand"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch"
                  VerticalContentAlignment="Stretch"
                  Click="OnLactatingCardClick">
            <Border x:Name="LactatingStageBorder"
                    Background="{Binding IsLactatingSelected, Converter={StaticResource BoolToBackgroundConverter}}"
                    BorderBrush="{Binding IsLactatingSelected, Converter={StaticResource BoolToBorderBrushConverter}}"
                    BorderThickness="{Binding IsLactatingSelected, Converter={StaticResource BoolToBorderThicknessConverter}}"
                    CornerRadius="8" 
                    Padding="12" 
                    Margin="4">
            <StackPanel x:Name="LactatingContentStackPanel">
              <TextBlock x:Name="LactatingTitleTextBlock"
                         Text="LACTATING" 
                         FontSize="14" 
                         FontWeight="Bold" 
                         Foreground="#388E3C" 
                         HorizontalAlignment="Center" 
                         Margin="0,4,0,8"/>
              
              <TextBlock x:Name="LactatingCountTextBlock"
                         Text="{Binding SelectedDairyComponentDto.SteadyStateLactating, StringFormat='{}{0} animals'}" 
                         FontSize="20" 
                         FontWeight="Bold" 
                         Foreground="#388E3C" 
                         HorizontalAlignment="Center"
                         Margin="0,0,0,8"/>
              
              <TextBlock x:Name="LactatingDaysTextBlock"
                         Text="{Binding SelectedDairyComponentDto.LactationDurationDays, StringFormat='{}{0} days in stage'}" 
                         FontSize="10" 
                         Foreground="#666" 
                         HorizontalAlignment="Center"
                         Margin="0,0,0,12"/>
              
              <!-- Integrated Calculation -->
              <Border x:Name="LactatingCalculationDetailsBorder"
                      Background="#E8F5E9" 
                      BorderBrush="#388E3C" 
                      BorderThickness="1"
                      CornerRadius="4" 
                      Padding="8"
                      IsVisible="{Binding ShowAdvancedOptions, RelativeSource={RelativeSource AncestorType={x:Type dairy:DairyComponentView}}}">
                <StackPanel x:Name="LactatingCalculationStackPanel">
                  <TextBlock x:Name="LactatingInputLabelTextBlock"
                             Text="User Input:" 
                             FontSize="9" 
                             FontWeight="SemiBold" 
                             Foreground="#388E3C"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,4"/>
                  <TextBlock x:Name="LactatingInputValueTextBlock"
                             TextWrapping="Wrap" 
                             FontSize="10" 
                             Foreground="#666"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,6">
                    <Run Text="{Binding SelectedDairyComponentDto.SteadyStateLactating, StringFormat='{}{0}'}" FontWeight="Bold" Foreground="#388E3C"/>
                    <Run Text=" animals present"/>
                  </TextBlock>
                  
                  <TextBlock x:Name="LactatingFormulaLabelTextBlock"
                             Text="Calculated Flow Rate:" 
                             FontSize="9" 
                             FontWeight="SemiBold" 
                             Foreground="#388E3C"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,4"/>
                  <TextBlock x:Name="LactatingFormulaTextBlock"
                             TextWrapping="Wrap" 
                             FontSize="9" 
                             Foreground="#666"
                             HorizontalAlignment="Center"
                             TextAlignment="Center"
                             LineHeight="13">
                    <Run Text="{Binding SelectedDairyComponentDto.SteadyStateLactating, StringFormat='{}{0}'}" FontWeight="SemiBold"/>
                    <Run Text=" / (305/365)"/>
                    <LineBreak/>
                    <Run Text="= "/>
                    <Run Text="{Binding SelectedDairyComponentDto.LactatingCowsEnteringPerYear}" FontWeight="Bold" Foreground="#388E3C"/>
                    <Run Text=" entering/yr"/>
                  </TextBlock>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>
        </Button>
          
          
          <!-- Dry -->
          <Button Grid.Column="3" 
                  Background="Transparent" 
                  BorderThickness="0" 
                  Padding="0"
                  Cursor="Hand"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch"
                  VerticalContentAlignment="Stretch"
                  Click="OnDryCardClick">
            <Border x:Name="DryStageBorder"
                    Background="{Binding IsDrySelected, Converter={StaticResource BoolToBackgroundConverter}}"
                    BorderBrush="{Binding IsDrySelected, Converter={StaticResource BoolToBorderBrushConverter}}"
                    BorderThickness="{Binding IsDrySelected, Converter={StaticResource BoolToBorderThicknessConverter}}"
                    CornerRadius="8" 
                    Padding="12" 
                    Margin="4">
            <StackPanel x:Name="DryContentStackPanel">
              <TextBlock x:Name="DryTitleTextBlock"
                         Text="DRY" 
                         FontSize="14" 
                         FontWeight="Bold" 
                         Foreground="#F57C00" 
                         HorizontalAlignment="Center" 
                         Margin="0,4,0,8"/>
              
              <TextBlock x:Name="DryCountTextBlock"
                         Text="{Binding SelectedDairyComponentDto.SteadyStateDry, StringFormat='{}{0} animals'}" 
                         FontSize="20" 
                         FontWeight="Bold" 
                         Foreground="#F57C00" 
                         HorizontalAlignment="Center"
                         Margin="0,0,0,8"/>
              
              <TextBlock x:Name="DryDaysTextBlock"
                         Text="{Binding SelectedDairyComponentDto.DryPeriodDays, StringFormat='{}{0} days in stage'}" 
                         FontSize="10" 
                         Foreground="#666" 
                         HorizontalAlignment="Center"
                         Margin="0,0,0,12"/>
              
              <!-- Integrated Calculation -->
              <Border x:Name="DryCalculationDetailsBorder"
                      Background="#FFF3E0" 
                      BorderBrush="#F57C00" 
                      BorderThickness="1"
                      CornerRadius="4" 
                      Padding="8"
                      IsVisible="{Binding ShowAdvancedOptions, RelativeSource={RelativeSource AncestorType={x:Type dairy:DairyComponentView}}}">
                <StackPanel x:Name="DryCalculationStackPanel">
                  <TextBlock x:Name="DryInputLabelTextBlock"
                             Text="User Input:" 
                             FontSize="9" 
                             FontWeight="SemiBold" 
                             Foreground="#F57C00"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,4"/>
                  <TextBlock x:Name="DryInputValueTextBlock"
                             TextWrapping="Wrap" 
                             FontSize="10" 
                             Foreground="#666"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,6">
                    <Run Text="{Binding SelectedDairyComponentDto.SteadyStateDry, StringFormat='{}{0}'}" FontWeight="Bold" Foreground="#F57C00"/>
                    <Run Text=" animals present"/>
                  </TextBlock>
                  
                  <TextBlock x:Name="DryFormulaLabelTextBlock"
                             Text="Calculated Flow Rate:" 
                             FontSize="9" 
                             FontWeight="SemiBold" 
                             Foreground="#F57C00"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,4"/>
                  <TextBlock x:Name="DryFormulaTextBlock"
                             TextWrapping="Wrap" 
                             FontSize="9" 
                             Foreground="#666"
                             HorizontalAlignment="Center"
                             TextAlignment="Center"
                             LineHeight="13">
                    <Run Text="{Binding SelectedDairyComponentDto.SteadyStateDry, StringFormat='{}{0}'}" FontWeight="SemiBold"/>
                    <Run Text=" / ("/>
                    <Run Text="{Binding SelectedDairyComponentDto.DryPeriodDays, StringFormat='{}{0}'}"/>
                    <Run Text="/365)"/>
                    <LineBreak/>
                    <Run Text="= "/>
                    <Run Text="{Binding SelectedDairyComponentDto.DryCowsEnteringPerYear}" FontWeight="Bold" Foreground="#F57C00"/>
                    <Run Text=" entering/yr"/>
                  </TextBlock>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>
        </Button>
          
          <!-- Total -->
          <Border x:Name="TotalBorder"
                  Grid.Column="4" 
                  Background="#43A047" 
                  CornerRadius="8" 
                  Padding="16" 
                  Margin="4"
                  VerticalAlignment="Stretch">
            <StackPanel x:Name="TotalContentStackPanel"
                        VerticalAlignment="Center">
              <TextBlock x:Name="TotalTitleTextBlock"
                         Text="TOTAL" 
                         FontSize="14" 
                         FontWeight="Bold" 
                         Foreground="White" 
                         HorizontalAlignment="Center" 
                         Margin="0,0,0,4"/>
              <TextBlock x:Name="TotalCountTextBlock"
                         Text="{Binding SelectedDairyComponentDto.TotalSteadyStateHerdSize, StringFormat='{}{0}'}" 
                         FontSize="24" 
                         FontWeight="Bold" 
                         Foreground="White" 
                         HorizontalAlignment="Center"
                         Margin="0,0,0,2"/>
              <TextBlock x:Name="TotalLabelTextBlock"
                         Text="animals" 
                         FontSize="10" 
                         Foreground="White" 
                         HorizontalAlignment="Center"/>
            </StackPanel>
          </Border>
        </Grid>
      </StackPanel>
    </StackPanel>
  </Border>
  
</UserControl>