<UserControl x:Name="HerdOverviewRootControl"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:converters="clr-namespace:H.Avalonia.Converters"
xmlns:dairy="clr-namespace:H.Avalonia.Views.ComponentViews.Dairy"
mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="400"
x:Class="H.Avalonia.Views.ComponentViews.Dairy.HerdOverviewView">
  
<UserControl.Resources>
  <converters:DivideByTwelveConverter x:Key="DivideByTwelveConverter"/>
</UserControl.Resources>
  
<!-- Step 1: Herd Parameters -->
<Border x:Name="StepContainerBorder" Classes="step-container">
  <StackPanel>
    <!-- Step Header -->
    <StackPanel x:Name="StepHeaderPanel" Margin="0,0,0,20">
      <Border x:Name="StepBadgeBorder" Classes="step-badge" HorizontalAlignment="Left">
        <TextBlock x:Name="StepNumberTextBlock" Text="Step 1" Classes="step-badge-text"/>
      </Border>
      <TextBlock x:Name="StepDescriptionTextBlock"
                 Text="Define Steady-State Herd Composition"
                 Classes="step-number-description"
                 Margin="0,8,0,0"/>
      <TextBlock x:Name="StepInstructionTextBlock"
                 Text="Proceed to Step 2 below to configure your herd by entering animal populations and lifecycle durations for each stage"
                 FontSize="13"
                 Foreground="#555"
                 TextWrapping="Wrap"
                 Margin="0,8,0,0"/>
    </StackPanel>
  </StackPanel>
</Border>
  
</UserControl>
