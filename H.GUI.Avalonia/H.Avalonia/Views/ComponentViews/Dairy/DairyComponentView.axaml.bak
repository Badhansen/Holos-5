<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1400"
             x:Class="H.Avalonia.Views.ComponentViews.Dairy.DairyComponentView">
  
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="24">
      
      <!-- Header Section -->
      <Border Background="#1565C0" CornerRadius="8" Padding="24" Margin="0,0,0,24">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0">
            <TextBlock Text="Dairy Operation Configuration" FontSize="28" FontWeight="Bold" 
                      Foreground="White" Margin="0,0,0,8"/>
            <TextBlock Text="Configure your dairy herd using a lifecycle-based approach. Enter your herd overview, and we'll calculate the number of animals in each lifecycle stage automatically." 
                      TextWrapping="Wrap" FontSize="14" Foreground="White" Opacity="0.9" MaxWidth="800"/>
          </StackPanel>
          <Border Grid.Column="1" Background="White" Padding="16" CornerRadius="8" 
                 VerticalAlignment="Center" Margin="16,0,0,0">
            <StackPanel>
              <TextBlock Text="??" FontSize="48" HorizontalAlignment="Center"/>
              <TextBlock Text="Lifecycle" FontSize="14" FontWeight="SemiBold" 
                        HorizontalAlignment="Center" Foreground="#1565C0"/>
              <TextBlock Text="Approach" FontSize="14" FontWeight="SemiBold" 
                        HorizontalAlignment="Center" Foreground="#1565C0"/>
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <!-- Step 1: Herd Overview -->
      <Border BorderBrush="#43A047" BorderThickness="2" CornerRadius="8" Margin="0,0,0,20">
        <StackPanel>
          <!-- Step Header -->
          <Border Background="#43A047" CornerRadius="6,6,0,0" Padding="20">
            <Grid ColumnDefinitions="Auto,*,Auto">
              <Border Grid.Column="0" Background="White" Width="40" Height="40" 
                     CornerRadius="20" Margin="0,0,16,0">
                <TextBlock Text="1" FontSize="20" FontWeight="Bold" Foreground="#43A047" 
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="Herd Overview" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Define your total herd size and key production parameters" 
                          FontSize="14" Foreground="White" Opacity="0.95" Margin="0,4,0,0"/>
              </StackPanel>
              <TextBlock Grid.Column="2" Text="??" FontSize="28" VerticalAlignment="Center"/>
            </Grid>
          </Border>
          
          <!-- Step Content -->
          <Border Background="White" Padding="24">
            <StackPanel>
              <TextBlock Text="Enter Your Herd Parameters" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
              
              <!-- Input Grid -->
              <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" MaxWidth="900">
                <!-- Row 0 -->
                <Border Grid.Row="0" Grid.Column="0" Margin="0,0,10,16">
                  <StackPanel>
                    <TextBlock Text="Total Milking Cows" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox Text="100" Padding="10" FontSize="14" Watermark="Enter number of milking cows"/>
                    <TextBlock Text="Number of cows in the milking herd" FontSize="11" Foreground="#666" Margin="0,4,0,0"/>
                  </StackPanel>
                </Border>
                
                <Border Grid.Row="0" Grid.Column="1" Margin="10,0,0,16">
                  <StackPanel>
                    <TextBlock Text="Replacement Rate (%)" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox Text="30" Padding="10" FontSize="14" Watermark="Enter replacement rate"/>
                    <TextBlock Text="Percentage of herd replaced annually" FontSize="11" Foreground="#666" Margin="0,4,0,0"/>
                  </StackPanel>
                </Border>
                
                <!-- Row 1 -->
                <Border Grid.Row="1" Grid.Column="0" Margin="0,0,10,16">
                  <StackPanel>
                    <TextBlock Text="Calving Interval (months)" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox Text="14" Padding="10" FontSize="14" Watermark="Enter calving interval"/>
                    <TextBlock Text="Average months between calvings" FontSize="11" Foreground="#666" Margin="0,4,0,0"/>
                  </StackPanel>
                </Border>
                
                <Border Grid.Row="1" Grid.Column="1" Margin="10,0,0,16">
                  <StackPanel>
                    <TextBlock Text="Dry Period (days)" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox Text="60" Padding="10" FontSize="14" Watermark="Enter dry period length"/>
                    <TextBlock Text="Days before calving without milking" FontSize="11" Foreground="#666" Margin="0,4,0,0"/>
                  </StackPanel>
                </Border>
                
                <!-- Row 2 -->
                <Border Grid.Row="2" Grid.Column="0" Margin="0,0,10,0">
                  <StackPanel>
                    <TextBlock Text="Calf Mortality Rate (%)" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox Text="5" Padding="10" FontSize="14" Watermark="Enter mortality rate"/>
                    <TextBlock Text="Percentage of calves lost before 4 months" FontSize="11" Foreground="#666" Margin="0,4,0,0"/>
                  </StackPanel>
                </Border>
                
                <Border Grid.Row="2" Grid.Column="1" Margin="10,0,0,0">
                  <StackPanel>
                    <TextBlock Text="Female Calf Ratio (%)" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox Text="50" Padding="10" FontSize="14" Watermark="Enter female ratio"/>
                    <TextBlock Text="Expected percentage of female calves" FontSize="11" Foreground="#666" Margin="0,4,0,0"/>
                  </StackPanel>
                </Border>
              </Grid>

              <Button Content="Calculate Herd Composition" Padding="16,10" Margin="0,24,0,0"
                     Background="#43A047" Foreground="White" CornerRadius="4" 
                     FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Left"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <!-- Calculated Herd Composition Panel -->
      <Border Background="#E8F5E9" BorderBrush="#43A047" BorderThickness="2" 
             CornerRadius="8" Padding="20" Margin="0,0,0,24">
        <StackPanel>
          <Grid ColumnDefinitions="Auto,*">
            <TextBlock Grid.Column="0" Text="?" FontSize="24" Foreground="#43A047" 
                      Margin="0,0,12,0" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="Calculated Herd Composition" 
                      FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
          </Grid>
          
          <TextBlock Text="Based on your inputs, here's your calculated herd structure:" 
                    FontSize="13" Foreground="#666" Margin="0,8,0,16"/>
          
          <Grid ColumnDefinitions="*,*,*,*">
            <!-- Calves -->
            <Border Grid.Column="0" Background="White" CornerRadius="6" Padding="16" Margin="4">
              <StackPanel>
                <TextBlock Text="??" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Calves" FontSize="14" FontWeight="SemiBold" 
                          HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="95 animals" FontSize="20" FontWeight="Bold" 
                          Foreground="#1976D2" HorizontalAlignment="Center"/>
                <TextBlock Text="Birth to 4 months" FontSize="11" Foreground="#666" 
                          HorizontalAlignment="Center" Margin="0,4,0,0"/>
              </StackPanel>
            </Border>
            
            <!-- Heifers -->
            <Border Grid.Column="1" Background="White" CornerRadius="6" Padding="16" Margin="4">
              <StackPanel>
                <TextBlock Text="??" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Heifers" FontSize="14" FontWeight="SemiBold" 
                          HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="30 animals" FontSize="20" FontWeight="Bold" 
                          Foreground="#7B1FA2" HorizontalAlignment="Center"/>
                <TextBlock Text="Replacement stock" FontSize="11" Foreground="#666" 
                          HorizontalAlignment="Center" Margin="0,4,0,0"/>
              </StackPanel>
            </Border>
            
            <!-- Lactating -->
            <Border Grid.Column="2" Background="White" CornerRadius="6" Padding="16" Margin="4">
              <StackPanel>
                <TextBlock Text="??" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Lactating" FontSize="14" FontWeight="SemiBold" 
                          HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="86 animals" FontSize="20" FontWeight="Bold" 
                          Foreground="#388E3C" HorizontalAlignment="Center"/>
                <TextBlock Text="Producing milk" FontSize="11" Foreground="#666" 
                          HorizontalAlignment="Center" Margin="0,4,0,0"/>
              </StackPanel>
            </Border>
            
            <!-- Dry -->
            <Border Grid.Column="3" Background="White" CornerRadius="6" Padding="16" Margin="4">
              <StackPanel>
                <TextBlock Text="??" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Dry Cows" FontSize="14" FontWeight="SemiBold" 
                          HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="14 animals" FontSize="20" FontWeight="Bold" 
                          Foreground="#F57C00" HorizontalAlignment="Center"/>
                <TextBlock Text="Pre-calving rest" FontSize="11" Foreground="#666" 
                          HorizontalAlignment="Center" Margin="0,4,0,0"/>
              </StackPanel>
            </Border>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Step 2: Lifecycle Timeline -->
      <Border BorderBrush="#1976D2" BorderThickness="2" CornerRadius="8" Margin="0,0,0,20">
        <StackPanel>
          <Border Background="#1976D2" CornerRadius="6,6,0,0" Padding="20">
            <Grid ColumnDefinitions="Auto,*,Auto">
              <Border Grid.Column="0" Background="White" Width="40" Height="40" 
                     CornerRadius="20" Margin="0,0,16,0">
                <TextBlock Text="2" FontSize="20" FontWeight="Bold" Foreground="#1976D2" 
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="Lifecycle Configuration" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Configure management practices for each lifecycle stage" 
                          FontSize="14" Foreground="White" Opacity="0.95" Margin="0,4,0,0"/>
              </StackPanel>
              <TextBlock Grid.Column="2" Text="??" FontSize="28" VerticalAlignment="Center"/>
            </Grid>
          </Border>
          
          <Border Background="White" Padding="24">
            <StackPanel>
              <!-- Lifecycle Flow Visualization -->
              <Border Background="#F5F5F5" CornerRadius="8" Padding="24" Margin="0,0,0,24">
                <StackPanel>
                  <TextBlock Text="Dairy Cattle Lifecycle Flow" FontSize="16" FontWeight="SemiBold" 
                            HorizontalAlignment="Center" Margin="0,0,0,20"/>
                  
                  <Grid ColumnDefinitions="*,Auto,*,Auto,*,Auto,*" HorizontalAlignment="Center">
                    <Border Grid.Column="0" Background="#E3F2FD" CornerRadius="8" Padding="20" MinWidth="140">
                      <StackPanel>
                        <TextBlock Text="??" FontSize="36" HorizontalAlignment="Center"/>
                        <TextBlock Text="CALF" FontSize="14" FontWeight="Bold" 
                                  HorizontalAlignment="Center" Margin="0,8,0,4"/>
                        <TextBlock Text="0-4 months" FontSize="11" Foreground="#666" 
                                  HorizontalAlignment="Center"/>
                      </StackPanel>
                    </Border>
                    
                    <TextBlock Grid.Column="1" Text="?" FontSize="32" Foreground="#1976D2" 
                              VerticalAlignment="Center" Margin="12,0"/>
                    
                    <Border Grid.Column="2" Background="#F3E5F5" CornerRadius="8" Padding="20" MinWidth="140">
                      <StackPanel>
                        <TextBlock Text="??" FontSize="36" HorizontalAlignment="Center"/>
                        <TextBlock Text="HEIFER" FontSize="14" FontWeight="Bold" 
                                  HorizontalAlignment="Center" Margin="0,8,0,4"/>
                        <TextBlock Text="4mo-1st calving" FontSize="11" Foreground="#666" 
                                  HorizontalAlignment="Center"/>
                      </StackPanel>
                    </Border>
                    
                    <TextBlock Grid.Column="3" Text="?" FontSize="32" Foreground="#1976D2" 
                              VerticalAlignment="Center" Margin="12,0"/>
                    
                    <Border Grid.Column="4" Background="#E8F5E9" CornerRadius="8" Padding="20" MinWidth="140">
                      <StackPanel>
                        <TextBlock Text="??" FontSize="36" HorizontalAlignment="Center"/>
                        <TextBlock Text="LACTATING" FontSize="14" FontWeight="Bold" 
                                  HorizontalAlignment="Center" Margin="0,8,0,4"/>
                        <TextBlock Text="Post-calving" FontSize="11" Foreground="#666" 
                                  HorizontalAlignment="Center"/>
                      </StackPanel>
                    </Border>
                    
                    <TextBlock Grid.Column="5" Text="?" FontSize="32" Foreground="#1976D2" 
                              VerticalAlignment="Center" Margin="12,0"/>
                    
                    <Border Grid.Column="6" Background="#FFF3E0" CornerRadius="8" Padding="20" MinWidth="140">
                      <StackPanel>
                        <TextBlock Text="??" FontSize="36" HorizontalAlignment="Center"/>
                        <TextBlock Text="DRY" FontSize="14" FontWeight="Bold" 
                                  HorizontalAlignment="Center" Margin="0,8,0,4"/>
                        <TextBlock Text="Pre-calving" FontSize="11" Foreground="#666" 
                                  HorizontalAlignment="Center"/>
                      </StackPanel>
                    </Border>
                  </Grid>
                </StackPanel>
              </Border>

              <!-- Expanded Lifecycle Stage Cards -->
              <StackPanel>
                
                <!-- Calf Stage Card - EXPANDED -->
                <Border BorderBrush="#2196F3" BorderThickness="2" CornerRadius="8" Margin="0,0,0,16">
                  <StackPanel>
                    <Border Background="#E3F2FD" Padding="16" CornerRadius="6,6,0,0">
                      <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                        <Border Grid.Column="0" Background="#2196F3" Width="48" Height="48" 
                               CornerRadius="24" Margin="0,0,12,0">
                          <TextBlock Text="??" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                          <TextBlock Text="Calf Stage" FontSize="16" FontWeight="Bold"/>
                          <TextBlock Text="95 animals • Birth to 4 months • 2 phases" 
                                    FontSize="12" Foreground="#666" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="2" Background="White" Padding="8,4" 
                               CornerRadius="4" Margin="0,0,8,0">
                          <TextBlock Text="Configured ?" FontSize="11" Foreground="#43A047" FontWeight="SemiBold"/>
                        </Border>
                        <Button Grid.Column="3" Content="? Collapse" Padding="12,6" 
                               Background="#2196F3" Foreground="White" CornerRadius="4"/>
                      </Grid>
                    </Border>
                    
                    <!-- Expanded Content -->
                    <Border Background="White" Padding="20">
                      <StackPanel>
                        <TextBlock Text="Management Phases" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        
                        <Grid ColumnDefinitions="*,*">
                          <!-- Phase 1: Milk-Fed Period -->
                          <Border Grid.Column="0" Background="#F9F9F9" BorderBrush="#E0E0E0" 
                                 BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,6,0">
                            <StackPanel>
                              <TextBlock Text="Phase 1: Milk-Fed Period" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                              <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="?? " FontSize="11" Margin="0,0,4,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Days 1-90 (3 months)" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="?? " FontSize="11" Margin="0,0,4,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Individual pens" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="?? " FontSize="11" Margin="0,0,4,4"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="Milk replacer diet" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="?? " FontSize="11" Margin="0,0,4,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="45 ? 100 kg" FontSize="11" Foreground="#666"/>
                              </Grid>
                            </StackPanel>
                          </Border>
                          
                          <!-- Phase 2: Weaning Period -->
                          <Border Grid.Column="1" Background="#F9F9F9" BorderBrush="#E0E0E0" 
                                 BorderThickness="1" CornerRadius="6" Padding="16" Margin="6,0,0,0">
                            <StackPanel>
                              <TextBlock Text="Phase 2: Weaning Period" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                              <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="?? " FontSize="11" Margin="0,0,4,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Days 91-120 (1 month)" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="?? " FontSize="11" Margin="0,0,4,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Group housing" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="?? " FontSize="11" Margin="0,0,4,4"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="Starter grain + hay" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="?? " FontSize="11" Margin="0,0,4,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="100 ? 130 kg" FontSize="11" Foreground="#666"/>
                              </Grid>
                            </StackPanel>
                          </Border>
                        </Grid>
                        
                        <Border Background="#FFFEF7" BorderBrush="#FFD54F" BorderThickness="1" 
                               CornerRadius="6" Padding="12" Margin="0,16,0,0">
                          <Grid ColumnDefinitions="*,*">
                            <StackPanel Grid.Column="0">
                              <TextBlock Text="?? Manure: Solid storage" FontSize="12" Margin="0,0,0,4"/>
                              <TextBlock Text="?? Bedding: Straw" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                              <TextBlock Text="?? Mortality Rate: 5%" FontSize="12" Margin="0,0,0,4"/>
                              <TextBlock Text="?? Group Pairing: 1" FontSize="12"/>
                            </StackPanel>
                          </Grid>
                        </Border>
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </Border>

                <!-- Heifer Stage Card - EXPANDED -->
                <Border BorderBrush="#7B1FA2" BorderThickness="2" CornerRadius="8" Margin="0,0,0,16">
                  <StackPanel>
                    <Border Background="#F3E5F5" Padding="16" CornerRadius="6,6,0,0">
                      <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                        <Border Grid.Column="0" Background="#7B1FA2" Width="48" Height="48" 
                               CornerRadius="24" Margin="0,0,12,0">
                          <TextBlock Text="??" FontSize="24" HorizontalAlignment="Center" 
                                    VerticalAlignment="Center" Foreground="White"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                          <TextBlock Text="Heifer Stage" FontSize="16" FontWeight="Bold"/>
                          <TextBlock Text="30 animals • Replacement stock • 2 phases" 
                                    FontSize="12" Foreground="#666" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="2" Background="White" Padding="8,4" 
                               CornerRadius="4" Margin="0,0,8,0">
                          <TextBlock Text="Configured ?" FontSize="11" Foreground="#43A047" FontWeight="SemiBold"/>
                        </Border>
                        <Button Grid.Column="3" Content="? Collapse" Padding="12,6" 
                               Background="#7B1FA2" Foreground="White" CornerRadius="4"/>
                      </Grid>
                    </Border>
                    
                    <!-- Expanded Content -->
                    <Border Background="White" Padding="20">
                      <StackPanel>
                        <TextBlock Text="Management Phases" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        
                        <Grid ColumnDefinitions="*,*">
                          <!-- Phase 1: Growing Phase -->
                          <Border Grid.Column="0" Background="#F9F9F9" BorderBrush="#E0E0E0" 
                                 BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,6,0">
                            <StackPanel>
                              <TextBlock Text="Phase 1: Growing Phase" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                              <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="?? " FontSize="11" Margin="0,0,4,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="4-12 months (240 days)" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="?? " FontSize="11" Margin="0,0,4,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Free stall barn" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="?? " FontSize="11" Margin="0,0,4,4"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="Forage-based diet" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="?? " FontSize="11" Margin="0,0,4,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="130 ? 350 kg" FontSize="11" Foreground="#666"/>
                              </Grid>
                            </StackPanel>
                          </Border>
                          
                          <!-- Phase 2: Breeding Phase -->
                          <Border Grid.Column="1" Background="#F9F9F9" BorderBrush="#E0E0E0" 
                                 BorderThickness="1" CornerRadius="6" Padding="16" Margin="6,0,0,0">
                            <StackPanel>
                              <TextBlock Text="Phase 2: Breeding Phase" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                              <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="?? " FontSize="11" Margin="0,0,4,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="12-24 months (365 days)" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="?? " FontSize="11" Margin="0,0,4,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Free stall barn" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="?? " FontSize="11" Margin="0,0,4,4"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="Balanced TMR diet" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="?? " FontSize="11" Margin="0,0,4,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="350 ? 600 kg" FontSize="11" Foreground="#666"/>
                              </Grid>
                            </StackPanel>
                          </Border>
                        </Grid>
                        
                        <Border Background="#FFFEF7" BorderBrush="#FFD54F" BorderThickness="1" 
                               CornerRadius="6" Padding="12" Margin="0,16,0,0">
                          <Grid ColumnDefinitions="*,*">
                            <StackPanel Grid.Column="0">
                              <TextBlock Text="?? Manure: Liquid slurry" FontSize="12" Margin="0,0,0,4"/>
                              <TextBlock Text="?? Bedding: Sand/Sawdust" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                              <TextBlock Text="?? Target: First calving at 24 mo" FontSize="12" Margin="0,0,0,4"/>
                              <TextBlock Text="?? Group Pairing: N/A" FontSize="12"/>
                            </StackPanel>
                          </Grid>
                        </Border>
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </Border>

                <!-- Lactating Stage Card - EXPANDED -->
                <Border BorderBrush="#388E3C" BorderThickness="2" CornerRadius="8" Margin="0,0,0,16">
                  <StackPanel>
                    <Border Background="#E8F5E9" Padding="16" CornerRadius="6,6,0,0">
                      <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                        <Border Grid.Column="0" Background="#388E3C" Width="48" Height="48" 
                               CornerRadius="24" Margin="0,0,12,0">
                          <TextBlock Text="??" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                          <TextBlock Text="Lactating Stage" FontSize="16" FontWeight="Bold"/>
                          <TextBlock Text="86 animals • Milk production • 4 lactation phases" 
                                    FontSize="12" Foreground="#666" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="2" Background="White" Padding="8,4" 
                               CornerRadius="4" Margin="0,0,8,0">
