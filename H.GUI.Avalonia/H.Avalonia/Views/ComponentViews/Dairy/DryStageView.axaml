<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000"
             x:Class="H.Avalonia.Views.ComponentViews.Dairy.DryStageView">
  
  <!-- Dry Stage Card -->
  <Border BorderBrush="#F57C00" BorderThickness="2" CornerRadius="8">
  <StackPanel>
    <Border Background="#FFF3E0" Padding="16" CornerRadius="6,6,0,0">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto">
        <Border Grid.Column="0" Background="#F57C00" Width="48" Height="48" 
               CornerRadius="24" Margin="0,0,12,0">
          <TextBlock Text="•" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <StackPanel Grid.Column="1" VerticalAlignment="Center">
          <TextBlock Text="Dry Period Stage" FontSize="16" FontWeight="Bold"/>
          <TextBlock Text="14 animals • Pre-calving rest • 2 phases" 
                    FontSize="12" Foreground="#666" Margin="0,2,0,0"/>
        </StackPanel>
        <Border Grid.Column="2" Background="White" Padding="8,4" 
               CornerRadius="4" Margin="0,0,8,0">
          <TextBlock Text="Configured" FontSize="11" Foreground="#43A047" FontWeight="SemiBold"/>
        </Border>
        <Button Grid.Column="3" Content="Collapse" Padding="12,6" 
               Background="#F57C00" Foreground="White" CornerRadius="4"/>
      </Grid>
    </Border>
    
    <!-- Expanded Content -->
    <Border Background="White" Padding="20">
      <StackPanel>
        <TextBlock Text="Management Phases" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
        
        <Grid ColumnDefinitions="*,*">
          <!-- Phase 1: Far-off Dry Period -->
          <Border Grid.Column="0" Background="#F9F9F9" BorderBrush="#E0E0E0" 
                 BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,6,0">
            <StackPanel>
              <TextBlock Text="Phase 1: Far-off Dry" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
              <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="• " FontSize="11" Margin="0,0,4,4"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="Days 1-45" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="• " FontSize="11" Margin="0,0,4,4"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="Dry cow pen" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="• " FontSize="11" Margin="0,0,4,4"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="Low energy forage" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="• " FontSize="11" Margin="0,0,4,0"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="680 kg avg weight" FontSize="11" Foreground="#666"/>
              </Grid>
            </StackPanel>
          </Border>
          
          <!-- Phase 2: Close-up Period -->
          <Border Grid.Column="1" Background="#F9F9F9" BorderBrush="#E0E0E0" 
                 BorderThickness="1" CornerRadius="6" Padding="16" Margin="6,0,0,0">
            <StackPanel>
              <TextBlock Text="Phase 2: Close-up Period" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
              <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="• " FontSize="11" Margin="0,0,4,4"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="Days 46-60" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="• " FontSize="11" Margin="0,0,4,4"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="Maternity pen" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="• " FontSize="11" Margin="0,0,4,4"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="Transition diet" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="• " FontSize="11" Margin="0,0,4,0"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="700 kg avg weight" FontSize="11" Foreground="#666"/>
              </Grid>
            </StackPanel>
          </Border>
        </Grid>
        
        <Border Background="#FFFEF7" BorderBrush="#FFD54F" BorderThickness="1" 
               CornerRadius="6" Padding="12" Margin="0,16,0,0">
          <Grid ColumnDefinitions="*,*">
            <StackPanel Grid.Column="0">
              <TextBlock Text="• Manure: Pack manure" FontSize="12" Margin="0,0,0,4"/>
              <TextBlock Text="• Bedding: Straw pack" FontSize="12"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
              <TextBlock Text="• Purpose: Prep for calving" FontSize="12" Margin="0,0,0,4"/>
              <TextBlock Text="• Group Pairing: N/A" FontSize="12"/>
            </StackPanel>
          </Grid>
        </Border>
      </StackPanel>
    </Border>
  </StackPanel>
</Border>
  
</UserControl>