<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:componentViews="clr-namespace:H.Avalonia.ViewModels.ComponentViews"
             xmlns:infrastructure="clr-namespace:H.Avalonia.Infrastructure;assembly=H.Avalonia.Infrastructure"
			 xmlns:properties="clr-namespace:H.Core.Properties;assembly=H.Core"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="950"
             x:Class="H.Avalonia.Views.ComponentViews.ChooseComponentsView">

    <Design.DataContext>
        <componentViews:ChooseComponentsViewModelDesign/>
    </Design.DataContext>

    <UserControl.Resources>
        <infrastructure:EnumDescriptionConverter x:Key="EnumDescriptionConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>

			<!-- Title row -->
            <RowDefinition Height="Auto"/>

			<!-- Content row -->
            <RowDefinition/>

            <!-- Gridsplitter row -->
            <RowDefinition Height="Auto"/>

			<!-- Command row -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>

			<!-- Main content column -->
            <ColumnDefinition Width="1*"/>

			<!-- Gridsplitter column -->
            <ColumnDefinition Width="Auto"/>

			<!-- Component description column -->
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <Grid Name="TitleGrid" 
              Grid.Row="0"
              Grid.Column="0"
              Grid.ColumnSpan="3"
              VerticalAlignment="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Margin="10,0" VerticalAlignment="Center">
                <!-- Combined Header and Instructions Card -->
                <Border Background="#F8F9FA" 
                       BorderBrush="#E9ECEF" 
                       BorderThickness="1" 
                       CornerRadius="6" 
                       Padding="20,16" 
                       Margin="0,10,0,10">
                    <StackPanel Spacing="12">
                        <!-- Main Title -->
                        <TextBlock Text="{x:Static properties:Resources.ChooseComponents}" 
                                  Classes="title-textblock"
                                  Margin="0"/>
                        
                        <!-- Horizontal Separator Line -->
                        <Border BorderBrush="#D0D0D0" 
                               BorderThickness="0,1,0,0" 
                               Margin="0,8,0,12"/>
                        
                        <!-- Instructions Header -->
                        <TextBlock Text="Follow these steps to add components to your farm:" 
                                  FontWeight="SemiBold" 
                                  FontSize="14" 
                                  Foreground="#495057"/>
                        
                        <!-- Step Instructions -->
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Classes="step-badge">
                                    <TextBlock Text="1" Classes="step-badge-text"/>
                                </Border>
                                <TextBlock Text="Choose a component from the categories below" 
                                          FontSize="13" 
                                          Foreground="#6C757D" 
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Classes="step-badge">
                                    <TextBlock Text="2" Classes="step-badge-text"/>
                                </Border>
                                <TextBlock Text="Click the 'Add This Component' button in the description panel" 
                                          FontSize="13" 
                                          Foreground="#6C757D" 
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Classes="step-badge">
                                    <TextBlock Text="3" Classes="step-badge-text"/>
                                </Border>
                                <TextBlock Text="When finished adding components, click 'Finish Selecting Components'" 
                                          FontSize="13" 
                                          Foreground="#6C757D" 
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <Grid Name="AvailableComponentsGrid" 
              Grid.Row="1"
              Grid.Column="0">

            <Border Background="#F8F9FA" 
                   BorderBrush="#E9ECEF" 
                   BorderThickness="1" 
                   CornerRadius="6" 
                   Padding="16,12" 
                   Margin="10,0,10,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding GroupedComponents}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,8">
                                    <!-- Category Expander -->
                                    <Expander IsExpanded="True" HorizontalAlignment="Stretch">
                                        <Expander.Header>
                                            <Border Padding="8,6"
                                                   HorizontalAlignment="Stretch">
                                                <TextBlock Text="{Binding CategoryName}" 
                                                          FontWeight="Bold" 
                                                          FontSize="14" 
                                                          Foreground="#2C3E50"/>
                                            </Border>
                                        </Expander.Header>

                                        <!-- Components in Category -->
                                        <ItemsControl ItemsSource="{Binding Components}" Margin="12,4,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Background="Transparent"
                                                           BorderThickness="0"
                                                           Padding="0"
                                                           HorizontalContentAlignment="Stretch"
                                                           HorizontalAlignment="Stretch"
                                                           Command="{Binding $parent[UserControl].DataContext.SelectComponentCommand}"
                                                           CommandParameter="{Binding}"
                                                           Margin="0,1">
                                                        <Border Padding="12,8" 
                                                               Background="Transparent"
                                                               BorderBrush="Transparent"
                                                               BorderThickness="1"
                                                               CornerRadius="4"
                                                               HorizontalAlignment="Stretch">
                                                            <Border.Styles>
                                                                <Style Selector="Border:pointerover">
                                                                    <Setter Property="Background" Value="#F8F9FA"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource DefaultHighlightBrush}"/>
                                                                </Style>
                                                            </Border.Styles>
                                                            
                                                            <!-- Component Name (Always Visible) -->
                                                            <TextBlock Text="{Binding Path=ComponentType, Converter={StaticResource EnumDescriptionConverter}}"
                                                                      VerticalAlignment="Center"
                                                                      HorizontalAlignment="Left"
                                                                      FontWeight="Medium"
                                                                      FontSize="13"
                                                                      Foreground="#2C3E50"/>
                                                        </Border>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <GridSplitter Grid.Column="1" Grid.Row="1" VerticalAlignment="Stretch"></GridSplitter>

        <Grid Name="DescriptionGrid" 
              Grid.Row="1"
              Grid.Column="2">
            <Border Background="#F8F9FA" 
                   BorderBrush="#E9ECEF" 
                   BorderThickness="1" 
                   CornerRadius="6" 
                   Padding="16,12" 
                   Margin="10,0,10,0">
                <StackPanel Margin="10">
                    <!-- Component Title -->
                    <TextBlock FontSize="20" Classes="title-textblock" Text="{Binding Path=SelectedComponentTitle}"/>
                    
                    <!-- Horizontal Separator Line -->
                    <Border BorderBrush="#D0D0D0" 
                           BorderThickness="0,1,0,0" 
                           Margin="0,12,0,16"/>
                    
                    <!-- Component Description -->
                    <TextBlock FontSize="16" TextWrapping="Wrap" Margin="0,0,0,0" Text="{Binding Path=SelectedComponentDescription}"/>
                    
                    <!-- Add Component Button - Using same responsive-button styling -->
                    <Button Content="Add This Component" 
                           Command="{Binding OnAddComponentExecute}"
                           Classes="responsive-button"
                           HorizontalAlignment="Center"
                           Margin="0,30,0,10"
                           MinWidth="180"
                           MaxWidth="220"
                           IsVisible="{Binding SelectedComponent, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Button.Styles>
                            <Style Selector="Button.responsive-button">
                                <Setter Property="Background" Value="MediumAquamarine"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                   
                    <!-- Helper text -->
                    <TextBlock Text="This component will be added to your farm"
                              FontStyle="Italic"
                              FontSize="12"
                              Foreground="Gray"
                              HorizontalAlignment="Center"
                              IsVisible="{Binding SelectedComponent, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                </StackPanel>
            </Border>
        </Grid>

		<Grid Name="CommandGrid" 
              Grid.Row="3"
              Grid.Column="0"
              Grid.ColumnSpan="3"
              Height="100">
            <Border Classes="component-border">
                <WrapPanel HorizontalAlignment="Center" 
                          VerticalAlignment="Center" 
                          Orientation="Horizontal" 
                          Margin="10">
                    
                    <!-- Finish Button with same styling as MyComponentsView -->
                    <Button Content="{x:Static properties:Resources.LabelFinishSelectComponent}" 
                           Command="{Binding OnFinishedAddingComponentsExecute}"
                           Classes="responsive-button"
                           Margin="5"/>
                           
                </WrapPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
