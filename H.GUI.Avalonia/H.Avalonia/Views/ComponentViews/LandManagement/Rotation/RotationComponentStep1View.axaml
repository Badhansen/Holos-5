<UserControl xmlns="https://github.com/avaloniaui"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         xmlns:field="clr-namespace:H.Avalonia.ViewModels.ComponentViews.LandManagement.Field"
         xmlns:rotation="clr-namespace:H.Avalonia.ViewModels.ComponentViews.LandManagement.Rotation"
         xmlns:rotationViews="clr-namespace:H.Avalonia.Views.ComponentViews.LandManagement.Rotation"
         xmlns:enums="clr-namespace:H.Core.Enumerations;assembly=H.Core"
         xmlns:converters="clr-namespace:H.Avalonia.Converters"
         mc:Ignorable="d"
         x:Class="H.Avalonia.Views.ComponentViews.LandManagement.Rotation.RotationComponentStep1View">

<Design.DataContext>
    <rotation:RotationComponentViewModelDesign/>
</Design.DataContext>

<UserControl.Resources>
    <converters:EnumToBoolConverter x:Key="EnumToBoolConverter"/>
</UserControl.Resources>

    <StackPanel Grid.IsSharedSizeScope="True">
        <!-- Step Header with Vertical Layout -->
        <StackPanel Margin="0,0,0,20">
            <!-- Step Badge -->
            <Border Classes="step-badge" HorizontalAlignment="Left">
                <TextBlock Text="Step 1" Classes="step-badge-text"/>
            </Border>
            
            <!-- Step Description below badge -->
            <TextBlock Text="Enter basic information for this crop rotation"
                       Classes="step-number-description"
                       Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Field Size Input Card -->
        <Border Classes="input-card">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                    <ColumnDefinition Width="Auto" MinWidth="120" SharedSizeGroup="InputColumn"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="UnitColumn"/>
                </Grid.ColumnDefinitions>
                
                <!-- Input row -->
                <TextBlock Grid.Column="0" Grid.Row="0"
                           Text="Field size:" 
                           FontWeight="Medium" 
                           Foreground="RoyalBlue"
                           VerticalAlignment="Center"/>
                <NumericUpDown Grid.Column="1" Grid.Row="0" 
                               Minimum="0" 
                               Value="{Binding Path=SelectedRotationComponentDto.FieldArea}"
                               Margin="8,0"/>
                <Label Grid.Column="2" Grid.Row="0" 
                       Classes="unit-label" 
                       Content="{Binding Path=StorageService.Storage.ApplicationData.DisplayUnitStrings.HectaresString}" 
                       VerticalContentAlignment="Center"/>
                
                <!-- Hint text - only visible when ShowAdvancedOptions is true -->
                <TextBlock Grid.Column="0" 
                           Grid.Row="1" 
                           Grid.ColumnSpan="3" 
                           Classes="input-hint"
                           Text="All fields in rotation must have an equal size" 
                           IsVisible="{Binding ShowAdvancedOptions, RelativeSource={RelativeSource AncestorType=rotationViews:RotationComponentView}}"/>
            </Grid>
        </Border>
        
        <!-- Start Year Input Card -->
        <Border Classes="input-card">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                    <ColumnDefinition Width="Auto" MinWidth="120" SharedSizeGroup="InputColumn"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="UnitColumn"/>
                </Grid.ColumnDefinitions>
                
                <!-- Input row -->
                <TextBlock Grid.Column="0" Grid.Row="0" 
                           Text="Start year:" 
                           FontWeight="Medium" 
                           Foreground="RoyalBlue"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <NumericUpDown Grid.Column="1" Grid.Row="0" 
                               Minimum="0" 
                               FormatString="0"
                               ParsingNumberStyle="Integer"
                               Value="{Binding Path=SelectedRotationComponentDto.StartYear}"
                               Margin="8,0"
                               HorizontalAlignment="Stretch"/>
                <TextBlock Grid.Column="2" Grid.Row="0" 
                           Text="" 
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
                
                <!-- Hint text - only visible when ShowAdvancedOptions is true -->
                <TextBlock Grid.Column="0" 
                           Grid.Row="1" 
                           Grid.ColumnSpan="3" 
                           Classes="input-hint"
                           Text="The year that defines the start of the field history" 
                           IsVisible="{Binding ShowAdvancedOptions, RelativeSource={RelativeSource AncestorType=rotationViews:RotationComponentView}}"/>
            </Grid>
        </Border>

        <!-- End Year Input Card -->
        <Border Classes="input-card">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                    <ColumnDefinition Width="Auto" MinWidth="120" SharedSizeGroup="InputColumn"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="UnitColumn"/>
                </Grid.ColumnDefinitions>
                
                <!-- Input row -->
                <TextBlock Grid.Column="0" Grid.Row="0" 
                           Text="End year:" 
                           FontWeight="Medium" 
                           Foreground="RoyalBlue"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <NumericUpDown Grid.Column="1" Grid.Row="0" 
                               Minimum="0" 
                               FormatString="0"
                               ParsingNumberStyle="Integer"
                               Value="{Binding Path=SelectedRotationComponentDto.EndYear}"
                               Margin="8,0"
                               HorizontalAlignment="Stretch"/>
                <TextBlock Grid.Column="2" Grid.Row="0" 
                           Text="" 
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
                
                <!-- Hint text - only visible when ShowAdvancedOptions is true -->
                <TextBlock Grid.Row="1" 
                           Grid.Column="0" 
                           Grid.ColumnSpan="3" 
                           Classes="input-hint"
                           Text="The year that defines the end of the field history" 
                           IsVisible="{Binding ShowAdvancedOptions, RelativeSource={RelativeSource AncestorType=rotationViews:RotationComponentView}}"/>
            </Grid>
        </Border>

        <!-- Number of Fields Input Card -->
        <Border Classes="input-card">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                    <ColumnDefinition Width="Auto" MinWidth="120" SharedSizeGroup="InputColumn"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="UnitColumn"/>
                </Grid.ColumnDefinitions>
                
                <!-- Input row -->
                <TextBlock Grid.Column="0" Grid.Row="0" 
                           Text="Number of fields:" 
                           FontWeight="Medium" 
                           Foreground="RoyalBlue"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <NumericUpDown Grid.Column="1" Grid.Row="0" 
                               Minimum="1" 
                               FormatString="0"
                               ParsingNumberStyle="Integer"
                               Value="{Binding Path=SelectedRotationComponentDto.NumberOfFields}"
                               Margin="8,0"
                               HorizontalAlignment="Stretch"/>
                <TextBlock Grid.Column="2" Grid.Row="0" 
                           Text="fields" 
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
                
                <!-- Hint text - only visible when ShowAdvancedOptions is true -->
                <TextBlock Grid.Row="1" 
                           Grid.Column="0" 
                           Grid.ColumnSpan="3" 
                           Classes="input-hint"
                           Text="How many fields will participate in this rotation" 
                           IsVisible="{Binding ShowAdvancedOptions, RelativeSource={RelativeSource AncestorType=rotationViews:RotationComponentView}}"/>
            </Grid>
        </Border>

        <!-- Rotation Shift Direction Card -->
        <Border Classes="input-card">
            <StackPanel>
                <!-- Header -->
                <TextBlock Text="Rotation shift direction:" 
                           FontWeight="Medium" 
                           Foreground="RoyalBlue"
                           Margin="0,0,0,12"/>
                
                <!-- Radio Button Group -->
                <StackPanel Spacing="8">
                    <!-- No Shift Option -->
                    <RadioButton GroupName="ShiftDirection"
                                 IsChecked="{Binding ShiftDirection, 
                                             Converter={StaticResource EnumToBoolConverter}, 
                                             ConverterParameter={x:Static enums:RotationShiftDirection.None}}">
                        <StackPanel>
                            <TextBlock Text="No Shift - All Fields Synchronized" 
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="All fields grow the same crops in the same years" 
                                       FontSize="11"
                                       Foreground="Gray"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Right Shift Option (Traditional) -->
                    <RadioButton GroupName="ShiftDirection"
                                 IsChecked="{Binding ShiftDirection, 
                                             Converter={StaticResource EnumToBoolConverter}, 
                                             ConverterParameter={x:Static enums:RotationShiftDirection.RightShift}}">
                        <StackPanel>
                            <TextBlock Text="Right Shift - Traditional Rotation ?" 
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Each field starts one position later in the sequence (most common)" 
                                       FontSize="11"
                                       Foreground="Gray"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Left Shift Option (Reverse) -->
                    <RadioButton GroupName="ShiftDirection"
                                 IsChecked="{Binding ShiftDirection, 
                                             Converter={StaticResource EnumToBoolConverter}, 
                                             ConverterParameter={x:Static enums:RotationShiftDirection.LeftShift}}">
                        <StackPanel>
                            <TextBlock Text="? Left Shift - Reverse Rotation" 
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Each field starts one position earlier in the sequence (alternative strategy)" 
                                       FontSize="11"
                                       Foreground="Gray"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <!-- Additional Hint - only visible when ShowAdvancedOptions is true -->
                <TextBlock Classes="input-hint"
                           Text="The shift direction determines how crops rotate across fields over time. Traditional (right) shift staggers planting and harvest across fields." 
                           Margin="0,12,0,0"
                           IsVisible="{Binding ShowAdvancedOptions, RelativeSource={RelativeSource AncestorType=rotationViews:RotationComponentView}}"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
