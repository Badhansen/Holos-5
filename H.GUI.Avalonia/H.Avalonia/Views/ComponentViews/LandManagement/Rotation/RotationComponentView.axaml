<UserControl xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:rotation="clr-namespace:H.Avalonia.ViewModels.ComponentViews.LandManagement.Rotation"
xmlns:shared="clr-namespace:H.Avalonia.Views.ComponentViews.Shared"
xmlns:properties="clr-namespace:H.Avalonia.Infrastructure.Properties;assembly=H.Avalonia.Infrastructure"
xmlns:rotationViews="clr-namespace:H.Avalonia.Views.ComponentViews.LandManagement.Rotation"
mc:Ignorable="d"
x:Class="H.Avalonia.Views.ComponentViews.LandManagement.Rotation.RotationComponentView">

<Design.DataContext>
<rotation:RotationComponentViewModelDesign/>
</Design.DataContext>


	<Grid>
		<Grid.RowDefinitions>
			<!-- Title -->
			<RowDefinition Height="Auto"/>
			<!-- Advanced Options Toggle -->
			<RowDefinition Height="Auto"/>
			<!-- Content -->
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0">
			<!-- Title -->
			<TextBox Classes="view-title" Text="{Binding Path=SelectedRotationComponentDto.Name}"/>
			<Border Classes="title-underline"/>
		</StackPanel>

		<!-- Advanced Options Toggle Section -->
		<shared:AdvancedOptionsToggleView Grid.Row="1"
										  Margin="{StaticResource DefaultUserControlMargin}"
										  Title="Show Advanced Options"
										  Description="Display additional configuration options for detailed crop rotation management"
										  IsChecked="{Binding ShowAdvancedOptions, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"/>

		<!-- Main Content Area with Timeline-Based Approach -->
		<ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
			<StackPanel Margin="0,0,0,40">
				
				<!-- Step 1: Rotation Overview -->
				<Border Classes="step-container"
						Margin="{StaticResource DefaultUserControlMargin}">
					<StackPanel>
						<!-- Step Header -->
						<StackPanel Margin="0,0,0,20">
							<Border Classes="step-badge" HorizontalAlignment="Left">
								<TextBlock Text="Step 1" Classes="step-badge-text"/>
							</Border>
							<TextBlock Text="Define Rotation Parameters"
									   Classes="step-number-description"
									   Margin="0,8,0,0"/>
						</StackPanel>

						<!-- Overview Content -->
						<Grid Grid.IsSharedSizeScope="True">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>

							<!-- Time Period Section -->
							<Border Grid.Column="0" Classes="input-card" Margin="0,0,8,0">
								<StackPanel>
									<TextBlock Text="? Time Period" FontWeight="Bold" Margin="0,0,0,12"/>
									
									<!-- Start Year -->
									<Grid Margin="0,0,0,8">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="Auto"/>
											<ColumnDefinition Width="*"/>
										</Grid.ColumnDefinitions>
										<TextBlock Grid.Column="0" Text="Start:" VerticalAlignment="Center" Margin="0,0,8,0"/>
										<NumericUpDown Grid.Column="1" 
													   Minimum="1900" 
													   Maximum="2200"
													   FormatString="0"
													   ParsingNumberStyle="Integer"
													   Value="{Binding Path=SelectedRotationComponentDto.StartYear}"/>
									</Grid>

									<!-- End Year -->
									<Grid Margin="0,0,0,8">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="Auto"/>
											<ColumnDefinition Width="*"/>
										</Grid.ColumnDefinitions>
										<TextBlock Grid.Column="0" Text="End:" VerticalAlignment="Center" Margin="0,0,8,0"/>
										<NumericUpDown Grid.Column="1" 
													   Minimum="1900" 
													   Maximum="2200"
													   FormatString="0"
													   ParsingNumberStyle="Integer"
													   Value="{Binding Path=SelectedRotationComponentDto.EndYear}"/>
									</Grid>

									<!-- Length (calculated) -->
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="Auto"/>
											<ColumnDefinition Width="*"/>
										</Grid.ColumnDefinitions>
										<TextBlock Grid.Column="0" Text="Length:" VerticalAlignment="Center" Margin="0,0,8,0"/>
										<TextBlock Grid.Column="1" 
												   Text="{Binding RotationLength}"
												   VerticalAlignment="Center"
												   FontWeight="SemiBold"/>
									</Grid>
								</StackPanel>
							</Border>

							<!-- Field Configuration Section -->
							<Border Grid.Column="1" Classes="input-card" Margin="0,0,8,0">
								<StackPanel>
									<TextBlock Text="?? Field Configuration" FontWeight="Bold" Margin="0,0,0,12"/>
									
									<!-- Number of Fields -->
									<Grid Margin="0,0,0,8">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="Auto"/>
											<ColumnDefinition Width="*"/>
										</Grid.ColumnDefinitions>
										<TextBlock Grid.Column="0" Text="Fields:" VerticalAlignment="Center" Margin="0,0,8,0"/>
										<NumericUpDown Grid.Column="1" 
													   Minimum="1" 
													   Maximum="20"
													   FormatString="0"
													   ParsingNumberStyle="Integer"
													   Value="{Binding NumberOfFields}"/>
									</Grid>

									<!-- Field Area -->
									<Grid Margin="0,0,0,8">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="Auto"/>
											<ColumnDefinition Width="*"/>
											<ColumnDefinition Width="Auto"/>
										</Grid.ColumnDefinitions>
										<TextBlock Grid.Column="0" Text="Area:" VerticalAlignment="Center" Margin="0,0,8,0"/>
										<NumericUpDown Grid.Column="1" 
													   Minimum="0.1"
													   Value="{Binding Path=SelectedRotationComponentDto.FieldArea}"/>
										<Label Grid.Column="2" 
											   Classes="unit-label"
											   Content="{Binding Path=StorageService.Storage.ApplicationData.DisplayUnitStrings.HectaresString}"
											   VerticalContentAlignment="Center"
											   Margin="4,0,0,0"/>
									</Grid>

									<!-- Shift Rotation Checkbox -->
									<CheckBox Content="Shift rotation across fields each year"
											  IsChecked="{Binding ShiftRotationEnabled}"
											  ToolTip.Tip="When enabled, crops rotate to different fields each year (e.g., Field 1 ? Field 2 ? Field 3)"/>
								</StackPanel>
							</Border>

							<!-- Rotation Summary Section -->
							<Border Grid.Column="2" Classes="input-card" Background="#E3F2FD">
								<StackPanel>
									<TextBlock Text="?? Rotation Summary" FontWeight="Bold" Margin="0,0,0,12"/>
									
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="Auto"/>
											<ColumnDefinition Width="*"/>
										</Grid.ColumnDefinitions>
										<Grid.RowDefinitions>
											<RowDefinition Height="Auto"/>
											<RowDefinition Height="Auto"/>
											<RowDefinition Height="Auto"/>
											<RowDefinition Height="Auto"/>
										</Grid.RowDefinitions>

										<!-- Total Area -->
										<TextBlock Grid.Row="0" Grid.Column="0" Text="Total area:" Margin="0,0,8,4"/>
										<TextBlock Grid.Row="0" Grid.Column="1" 
												   Text="{Binding TotalRotationArea, StringFormat='{}{0:F2} ha'}"
												   FontWeight="SemiBold"
												   HorizontalAlignment="Right"
												   Margin="0,0,0,4"/>

										<!-- Number of Fields -->
										<TextBlock Grid.Row="1" Grid.Column="0" Text="Fields:" Margin="0,0,8,4"/>
										<TextBlock Grid.Row="1" Grid.Column="1" 
												   Text="{Binding NumberOfFields}"
												   FontWeight="SemiBold"
												   HorizontalAlignment="Right"
												   Margin="0,0,0,4"/>

										<!-- Years per Field -->
										<TextBlock Grid.Row="2" Grid.Column="0" Text="Years/field:" Margin="0,0,8,4"/>
										<TextBlock Grid.Row="2" Grid.Column="1" 
												   Text="{Binding RotationLength}"
												   FontWeight="SemiBold"
												   HorizontalAlignment="Right"
												   Margin="0,0,0,4"/>

										<!-- Total Crop-Years -->
										<TextBlock Grid.Row="3" Grid.Column="0" Text="Crop-years:" Margin="0,0,8,0"/>
										<TextBlock Grid.Row="3" Grid.Column="1" 
												   Text="{Binding TotalCropYears}"
												   FontWeight="SemiBold"
												   HorizontalAlignment="Right"/>
									</Grid>
								</StackPanel>
							</Border>
						</Grid>
					</StackPanel>
				</Border>

				<!-- Step Divider -->
				<GridSplitter Height="2" 
							  Background="LightGray" 
							  HorizontalAlignment="Stretch"
							  Margin="{StaticResource DefaultUserControlMargin}"/>

				<!-- Step 2: Build Rotation Timeline -->
				<Border Classes="step-container"
						Margin="{StaticResource DefaultUserControlMargin}">
					<StackPanel>
						<!-- Step Header -->
						<StackPanel Margin="0,0,0,20">
							<Border Classes="step-badge" HorizontalAlignment="Left">
								<TextBlock Text="Step 2" Classes="step-badge-text"/>
							</Border>
							<TextBlock Text="Build Your Rotation Sequence"
									   Classes="step-number-description"
									   Margin="0,8,0,0"/>
							<TextBlock Text="Add crops to create your rotation timeline. Each crop represents one year in the sequence."
									   Foreground="Gray"
									   FontSize="12"
									   Margin="0,4,0,0"/>
						</StackPanel>

						<!-- Timeline Controls -->
						<StackPanel Orientation="Horizontal" Margin="0,0,0,12">
							<Button Content="+ Add Crop" 
									Command="{Binding AddCropToRotationCommand}"
									Margin="0,0,8,0"/>
							<Button Content="Remove Selected" 
									Command="{Binding RemoveSelectedCropCommand}"
									Margin="0,0,8,0"/>
							<TextBlock Text="Crops in sequence:" 
									   VerticalAlignment="Center"
									   Margin="8,0,8,0"/>
							<TextBlock Text="{Binding CropsInRotation.Count}"
									   FontWeight="Bold"
									   VerticalAlignment="Center"/>
						</StackPanel>

						<!-- Horizontal Timeline Scroll View -->
						<Border BorderBrush="LightGray" 
								BorderThickness="1" 
								CornerRadius="4"
								Background="White"
								MinHeight="180">
							<ScrollViewer HorizontalScrollBarVisibility="Auto" 
										  VerticalScrollBarVisibility="Disabled">
								<ItemsControl ItemsSource="{Binding CropsInRotation}">
									<ItemsControl.ItemsPanel>
										<ItemsPanelTemplate>
											<StackPanel Orientation="Horizontal" Margin="12"/>
										</ItemsPanelTemplate>
									</ItemsControl.ItemsPanel>
									<ItemsControl.ItemTemplate>
										<DataTemplate>
											<!-- Individual Crop Card in Timeline -->
											<Border Width="160"
													Margin="0,0,12,0"
													BorderThickness="2"
													CornerRadius="8"
													Padding="12"
													Background="{Binding IsSelected, Converter={StaticResource BoolToBackgroundConverter}}"
													BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToBorderBrushConverter}}"
													PointerPressed="OnCropCardPressed">
												<Border.RenderTransform>
													<ScaleTransform ScaleX="{Binding IsSelected, Converter={StaticResource BoolToScaleTransformConverter}}" 
																	ScaleY="{Binding IsSelected, Converter={StaticResource BoolToScaleTransformConverter}}"/>
												</Border.RenderTransform>
												<StackPanel>
													<!-- Year Label -->
													<TextBlock Text="{Binding YearLabel}"
															   FontSize="14"
															   FontWeight="Bold"
															   Foreground="DodgerBlue"
															   Margin="0,0,0,8"/>
													
													<!-- Crop Icon/Rectangle -->
													<Border Height="60"
															Background="{Binding CropColorBrush}"
															CornerRadius="4"
															Margin="0,0,0,8">
														<TextBlock Text="{Binding CropIcon}"
																   FontSize="32"
																   HorizontalAlignment="Center"
																   VerticalAlignment="Center"/>
													</Border>

													<!-- Crop Name -->
													<TextBlock Text="{Binding CropTypeName}"
															   FontWeight="SemiBold"
															   TextWrapping="Wrap"
															   TextAlignment="Center"
															   Margin="0,0,0,4"/>

													<!-- Crop Category -->
													<TextBlock Text="{Binding CropCategory}"
															   FontSize="11"
															   Foreground="Gray"
															   TextAlignment="Center"/>

													<!-- Edit Button -->
													<Button Content="Edit"
															Command="{Binding EditCropCommand}"
															HorizontalAlignment="Stretch"
															Margin="0,8,0,0"
															FontSize="11"/>
												</StackPanel>
											</Border>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</ScrollViewer>
						</Border>

						<!-- Empty State Message -->
						<Border IsVisible="{Binding HasNoCrops}"
								Background="#FFF3E0"
								BorderBrush="#FF9800"
								BorderThickness="1"
								CornerRadius="4"
								Padding="16"
								Margin="0,12,0,0">
							<StackPanel Orientation="Horizontal">
								<TextBlock Text="?" 
										   FontSize="20"
										   Margin="0,0,12,0"
										   VerticalAlignment="Center"/>
								<TextBlock Text="Add at least one crop to create your rotation"
										   VerticalAlignment="Center"/>
							</StackPanel>
						</Border>
					</StackPanel>
				</Border>

				<!-- Step Divider -->
				<GridSplitter Height="2" 
							  Background="LightGray" 
							  HorizontalAlignment="Stretch"
							  Margin="{StaticResource DefaultUserControlMargin}"/>

				<!-- Step 3: Preview (extracted to separate view) -->
				<rotationViews:RotationPreviewView DataContext="{Binding}"/>

				<!-- Step Divider -->
				<GridSplitter Height="2" 
							  Background="LightGray" 
							  HorizontalAlignment="Stretch"
							  Margin="{StaticResource DefaultUserControlMargin}"/>

				<!-- Step 4: Finalize (extracted to separate view) -->
				<rotationViews:RotationFinalizeView DataContext="{Binding}"/>

			</StackPanel>
		</ScrollViewer>
	</Grid>
</UserControl>
