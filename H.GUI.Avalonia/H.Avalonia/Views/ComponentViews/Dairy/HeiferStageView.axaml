<UserControl xmlns="https://github.com/avaloniaui"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
           xmlns:converters="clr-namespace:H.Avalonia.Converters"
           xmlns:infrastructure="clr-namespace:H.Avalonia.Infrastructure;assembly=H.Avalonia.Infrastructure"
           xmlns:dairy="clr-namespace:H.Avalonia.ViewModels.ComponentViews.Dairy"
           xmlns:dairyModel="clr-namespace:H.Core.Models.Animals.Dairy;assembly=H.Core"
           mc:Ignorable="d" d:DesignWidth="1000"
           x:Class="H.Avalonia.Views.ComponentViews.Dairy.HeiferStageView">

<Design.DataContext>
  <dairy:DairyComponentViewModelDesign/>
</Design.DataContext>

<UserControl.Resources>
  <converters:DivideByTwelveConverter x:Key="DivideByTwelveConverter"/>
  <infrastructure:EnumDescriptionConverter x:Key="EnumDescriptionConverter"/>
</UserControl.Resources>

<!-- Heifer Stage Card -->
  <StackPanel>

    <!-- Header with Add button -->
    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
      <TextBlock Grid.Column="0" Text="Management Phases" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
      <Button Grid.Column="1"
              Content="+ Add Practice"
              Command="{Binding AddHeiferManagementPracticeCommand}"
              Classes="accent"
              FontSize="12"
              Padding="12,6"/>
    </Grid>

    <!-- Dynamic Management Practices -->
    <ItemsControl ItemsSource="{Binding SelectedDairyComponentDto.HeiferManagementPractices}">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <WrapPanel Orientation="Horizontal"/>
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate DataType="dairyModel:DairyManagementPractice">
          <Border Background="#F9F9F9" BorderBrush="#E0E0E0"
                  BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,8,8"
                  MinWidth="280" MaxWidth="350">
            <StackPanel>
              <!-- Practice Name (editable) and Remove button -->
              <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                <TextBox Grid.Column="0"
                         Text="{Binding PracticeName}"
                         FontSize="13" FontWeight="SemiBold"
                         Watermark="Enter practice name"
                         BorderThickness="0" Background="Transparent"
                         Padding="0"/>
                <Button Grid.Column="1"
                        Command="{Binding $parent[ItemsControl].((dairy:DairyComponentViewModel)DataContext).RemoveManagementPracticeCommand}"
                        CommandParameter="{Binding}"
                        Background="Transparent"
                        ToolTip.Tip="Remove practice"
                        Padding="4">
                  <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                        Fill="Red" Width="14" Height="14" Stretch="Uniform"/>
                </Button>
              </Grid>

              <!-- Manure Handling System Selection -->
              <TextBlock Text="Manure Handling System:"
                        FontSize="12" FontWeight="SemiBold"
                        Margin="0,0,0,4"/>

              <ComboBox ItemsSource="{Binding $parent[ItemsControl].((dairy:DairyComponentViewModel)DataContext).ManureStateTypes}"
                       SelectedItem="{Binding ManureHandlingSystem}"
                       HorizontalAlignment="Stretch"
                       Margin="0,0,0,8">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}"
                              FontSize="11"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>

              <!-- Housing Type Selection -->
              <TextBlock Text="Housing Type:"
                        FontSize="12" FontWeight="SemiBold"
                        Margin="0,0,0,4"/>

              <ComboBox ItemsSource="{Binding $parent[ItemsControl].((dairy:DairyComponentViewModel)DataContext).HousingTypes}"
                       SelectedItem="{Binding HousingType}"
                       HorizontalAlignment="Stretch"
                       Margin="0,0,0,0">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}"
                              FontSize="11"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </StackPanel>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <!-- Empty state message -->
    <Border Background="#FFF3CD" BorderBrush="#FFC107" BorderThickness="1"
            CornerRadius="6" Padding="16" Margin="0,4,0,0"
            IsVisible="{Binding !SelectedDairyComponentDto.HeiferManagementPractices.Count}">
      <TextBlock Text="No management practices defined. Click '+ Add Practice' to add one."
                 FontSize="12" Foreground="#856404" TextAlignment="Center"
                 HorizontalAlignment="Center"/>
    </Border>

    <Border Background="#FFFEF7" BorderBrush="#FFD54F" BorderThickness="1"
           CornerRadius="6" Padding="12" Margin="0,16,0,0">
      <Grid ColumnDefinitions="*,*">
        <StackPanel Grid.Column="0">
          <TextBlock Text="Bedding: Sand/Sawdust" FontSize="12" Margin="0,0,0,4"/>
          <TextBlock Text="Group Pairing: N/A" FontSize="12"/>
        </StackPanel>
        <StackPanel Grid.Column="1">
          <TextBlock Text="Target: First calving at 24 mo" FontSize="12" Margin="0,0,0,4"/>
          <TextBlock Text="Monitoring: Regular" FontSize="12"/>
        </StackPanel>
      </Grid>
    </Border>
  </StackPanel>

</UserControl>
