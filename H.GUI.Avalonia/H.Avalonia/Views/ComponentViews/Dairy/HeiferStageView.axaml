<UserControl xmlns="https://github.com/avaloniaui"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
           xmlns:converters="clr-namespace:H.Avalonia.Converters"
           xmlns:infrastructure="clr-namespace:H.Avalonia.Infrastructure;assembly=H.Avalonia.Infrastructure"
           xmlns:dairy="clr-namespace:H.Avalonia.ViewModels.ComponentViews.Dairy"
           mc:Ignorable="d" d:DesignWidth="1000"
           x:Class="H.Avalonia.Views.ComponentViews.Dairy.HeiferStageView">

<Design.DataContext>
  <dairy:DairyComponentViewModelDesign/>
</Design.DataContext>
  
<UserControl.Resources>
  <converters:DivideByTwelveConverter x:Key="DivideByTwelveConverter"/>
  <infrastructure:EnumDescriptionConverter x:Key="EnumDescriptionConverter"/>
</UserControl.Resources>
  
<!-- Heifer Stage Card -->
  <Border BorderBrush="#7B1FA2" BorderThickness="2" CornerRadius="8" Margin="0,0,0,16">
    <Border Background="White" Padding="20">
      <StackPanel>
        
        <!-- NEW: Flow Rate Input Section -->
        <Border Background="#FFF9E6" BorderBrush="#FFA000" BorderThickness="1" 
               CornerRadius="6" Padding="16" Margin="0,0,0,16">
          <StackPanel>
            <TextBlock Text="🐄 Staggered Progression Input" 
                      FontSize="14" FontWeight="SemiBold" 
                      Foreground="#F57C00" Margin="0,0,0,8"/>
            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#666" 
                      Margin="0,0,0,12">
              Enter the number of heifers entering the replacement heifer stage per year. 
              These are animals transitioning from the calf stage into the growing/breeding phase.
            </TextBlock>
            
            <Grid ColumnDefinitions="Auto,200,*">
              <TextBlock Grid.Column="0" Text="Heifers Entering Per Year:" 
                        FontSize="13" VerticalAlignment="Center" Margin="0,0,12,0"/>
              <NumericUpDown Grid.Column="1" 
                            Value="{Binding SelectedDairyComponentDto.HeifersEnteringPerYear}"
                            Minimum="0" 
                            Maximum="10000"
                            Increment="1"
                            FormatString="N0"
                            Height="32"/>
              <TextBlock Grid.Column="2" Text="heifers/year" 
                        FontSize="12" Foreground="#666" 
                        VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>
            
            <!-- Helpful calculation note -->
            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                   CornerRadius="4" Padding="8" Margin="0,12,0,0">
              <StackPanel>
                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#666" 
                          FontStyle="Italic">
                  <Run Text="💡 Tip: "/>
                  <Run Text="{Binding SelectedDairyComponentDto.HeifersEnteringPerYear, StringFormat='{}{0:N0}'}" FontWeight="SemiBold"/>
                  <Run Text=" heifers/year ≈ "/>
                  <Run Text="{Binding SelectedDairyComponentDto.HeifersEnteringPerYear, Converter={StaticResource DivideByTwelveConverter}, StringFormat='{}{0:F1}'}" FontWeight="SemiBold"/>
                  <Run Text=" heifers/month"/>
                </TextBlock>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>
        
        <TextBlock Text="Management Phases" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
        
        <Grid ColumnDefinitions="*,*">
          <!-- Phase 1: Growing Phase -->
          <Border Grid.Column="0" Background="#F9F9F9" BorderBrush="#E0E0E0" 
                 BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,6,0">
            <StackPanel>
              <TextBlock Text="Phase 1: Growing Phase" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
              <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="• " FontSize="11" Margin="0,0,4,4"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="4-12 months (240 days)" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="• " FontSize="11" Margin="0,0,4,4"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="Forage-based diet" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="• " FontSize="11" Margin="0,0,4,0"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="130 → 350 kg" FontSize="11" Foreground="#666" Margin="0,0,0,8"/>
                
                <!-- Manure Handling System Selection -->
                <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" 
                          Text="Manure Handling System:" 
                          FontSize="12" FontWeight="SemiBold" 
                          Margin="0,8,0,4"/>
              </Grid>
              
              <ComboBox ItemsSource="{Binding ManureStateTypes}"
                       SelectedItem="{Binding SelectedDairyComponentDto.HeiferPhase1ManureHandlingSystem}"
                       HorizontalAlignment="Stretch"
                       Margin="0,0,0,8">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" 
                              FontSize="11"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              
              <!-- Housing Type Selection -->
              <TextBlock Text="Housing Type:" 
                        FontSize="12" FontWeight="SemiBold" 
                        Margin="0,0,0,4"/>
              
              <ComboBox ItemsSource="{Binding HousingTypes}"
                       SelectedItem="{Binding SelectedDairyComponentDto.HeiferPhase1HousingType}"
                       HorizontalAlignment="Stretch"
                       Margin="0,0,0,0">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" 
                              FontSize="11"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </StackPanel>
          </Border>
          
          <!-- Phase 2: Breeding Phase -->
          <Border Grid.Column="1" Background="#F9F9F9" BorderBrush="#E0E0E0" 
                 BorderThickness="1" CornerRadius="6" Padding="16" Margin="6,0,0,0">
            <StackPanel>
              <TextBlock Text="Phase 2: Breeding Phase" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
              <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="• " FontSize="11" Margin="0,0,4,4"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="12-24 months (365 days)" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="• " FontSize="11" Margin="0,0,4,4"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="Balanced TMR diet" FontSize="11" Foreground="#666" Margin="0,0,0,4"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="• " FontSize="11" Margin="0,0,4,0"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="350 → 600 kg" FontSize="11" Foreground="#666" Margin="0,0,0,8"/>
                
                <!-- Manure Handling System Selection -->
                <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" 
                          Text="Manure Handling System:" 
                          FontSize="12" FontWeight="SemiBold" 
                          Margin="0,8,0,4"/>
              </Grid>
              
              <ComboBox ItemsSource="{Binding ManureStateTypes}"
                       SelectedItem="{Binding SelectedDairyComponentDto.HeiferPhase2ManureHandlingSystem}"
                       HorizontalAlignment="Stretch"
                       Margin="0,0,0,8">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" 
                              FontSize="11"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              
              <!-- Housing Type Selection -->
              <TextBlock Text="Housing Type:" 
                        FontSize="12" FontWeight="SemiBold" 
                        Margin="0,0,0,4"/>
              
              <ComboBox ItemsSource="{Binding HousingTypes}"
                       SelectedItem="{Binding SelectedDairyComponentDto.HeiferPhase2HousingType}"
                       HorizontalAlignment="Stretch"
                       Margin="0,0,0,0">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" 
                              FontSize="11"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </StackPanel>
          </Border>
        </Grid>
        
        <Border Background="#FFFEF7" BorderBrush="#FFD54F" BorderThickness="1" 
               CornerRadius="6" Padding="12" Margin="0,16,0,0">
          <Grid ColumnDefinitions="*,*">
            <StackPanel Grid.Column="0">
              <TextBlock Text="• Bedding: Sand/Sawdust" FontSize="12" Margin="0,0,0,4"/>
              <TextBlock Text="• Group Pairing: N/A" FontSize="12"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
              <TextBlock Text="• Target: First calving at 24 mo" FontSize="12" Margin="0,0,0,4"/>
              <TextBlock Text="• Monitoring: Regular" FontSize="12"/>
            </StackPanel>
          </Grid>
        </Border>
      </StackPanel>
    </Border>
  </Border>
  
</UserControl>